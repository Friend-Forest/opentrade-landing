---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import HeroTerminal from '../components/HeroTerminal.astro';
import StatsTicker from '../components/StatsTicker.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AgentCards from '../components/AgentCards.astro';
import TokenomicsWheel from '../components/TokenomicsWheel.astro';
import Leaderboard from '../components/Leaderboard.astro';
import DeployCTA from '../components/DeployCTA.astro';
import MinimalFooter from '../components/MinimalFooter.astro';
---

<Layout
  title="OpenTrade — Autonomous AI Trading Agents on Base"
  description="Deploy AI agents that trade crypto 24/7. No emotions, pure alpha. Each agent has its own token with automatic fee & profit buybacks on Base."
>
  <Navigation />
  <main>
    <HeroTerminal />
    <StatsTicker />
    <HowItWorks />
    <AgentCards />
    <TokenomicsWheel />
    <Leaderboard />
    <DeployCTA />
  </main>
  <MinimalFooter />
</Layout>

<style is:global>
  @import '../styles/global.css';

  /* Smooth scroll offset for fixed nav */
  html { scroll-padding-top: 80px; }

  /* GSAP animation classes */
  .gsap-fade-up {
    opacity: 0;
    transform: translateY(40px);
  }

  .gsap-fade-in {
    opacity: 0;
  }

  .gsap-slide-left {
    opacity: 0;
    transform: translateX(-40px);
  }

  .gsap-slide-right {
    opacity: 0;
    transform: translateX(40px);
  }
</style>

<script>
  // GSAP scroll animations
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Section headings
  gsap.utils.toArray('.section-title').forEach((el: any) => {
    gsap.fromTo(el,
      { opacity: 0, y: 30 },
      {
        opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none reverse'
        }
      }
    );
  });

  // Section labels
  gsap.utils.toArray('.section-label').forEach((el: any) => {
    gsap.fromTo(el,
      { opacity: 0, x: -20 },
      {
        opacity: 1, x: 0, duration: 0.6, ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 90%',
          toggleActions: 'play none none reverse'
        }
      }
    );
  });

  // Hero content stagger
  gsap.fromTo('.hero-copy > *',
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out', delay: 0.3 }
  );

  gsap.fromTo('.hero-terminal-wrapper',
    { opacity: 0, x: -40, scale: 0.97 },
    { opacity: 1, x: 0, scale: 1, duration: 0.9, ease: 'power3.out', delay: 0.2 }
  );

  // Parallax on hero grid
  gsap.to('.hero-grid', {
    y: -60,
    ease: 'none',
    scrollTrigger: {
      trigger: '.hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 1
    }
  });

  // Stagger agent cards (already handled by IntersectionObserver, but GSAP for entrance)
  gsap.utils.toArray('.how-step').forEach((el: any, i: number) => {
    ScrollTrigger.create({
      trigger: el,
      start: 'top 80%',
      onEnter: () => {
        gsap.fromTo(el,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.6, delay: i * 0.15, ease: 'power3.out' }
        );
      }
    });
  });

  // Tokenomics reveal
  gsap.fromTo('.tokenomics-copy > *',
    { opacity: 0, x: -30 },
    {
      opacity: 1, x: 0, duration: 0.7, stagger: 0.1, ease: 'power3.out',
      scrollTrigger: {
        trigger: '.tokenomics-section',
        start: 'top 70%',
        toggleActions: 'play none none reverse'
      }
    }
  );

  gsap.fromTo('.wheel-container',
    { opacity: 0, scale: 0.8, rotationZ: -10 },
    {
      opacity: 1, scale: 1, rotationZ: 0, duration: 0.9, ease: 'back.out(1.2)',
      scrollTrigger: {
        trigger: '.tokenomics-section',
        start: 'top 70%',
        toggleActions: 'play none none reverse'
      }
    }
  );

  // Leaderboard rows (fallback if CSS animation not enough)
  gsap.utils.toArray('.lb-row').forEach((row: any, i: number) => {
    gsap.fromTo(row,
      { opacity: 0, x: -20 },
      {
        opacity: 1, x: 0, duration: 0.4, delay: i * 0.05, ease: 'power2.out',
        scrollTrigger: {
          trigger: '.leaderboard-table',
          start: 'top 80%',
          toggleActions: 'play none none none'
        }
      }
    );
  });

  // Deploy section split reveal
  gsap.fromTo('.deploy-left-content > *',
    { opacity: 0, x: -30 },
    {
      opacity: 1, x: 0, duration: 0.7, stagger: 0.1, ease: 'power3.out',
      scrollTrigger: {
        trigger: '.deploy-section',
        start: 'top 75%',
        toggleActions: 'play none none reverse'
      }
    }
  );

  gsap.fromTo('.deploy-terminal',
    { opacity: 0, x: 30, y: 10 },
    {
      opacity: 1, x: 0, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: {
        trigger: '.deploy-section',
        start: 'top 75%',
        toggleActions: 'play none none reverse'
      }
    }
  );
</script>
