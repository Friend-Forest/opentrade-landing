---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import HeroTerminal from '../components/HeroTerminal.astro';
import StatsTicker from '../components/StatsTicker.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AgentCards from '../components/AgentCards.astro';
import TokenomicsWheel from '../components/TokenomicsWheel.astro';
import Leaderboard from '../components/Leaderboard.astro';
import DeployCTA from '../components/DeployCTA.astro';
import MinimalFooter from '../components/MinimalFooter.astro';
---

<Layout
  title="OpenTrade — Autonomous AI Trading Agents on Base"
  description="Deploy AI agents that trade crypto 24/7. No emotions, pure alpha. Each agent has its own token with automatic fee & profit buybacks on Base."
>
  <Navigation />
  <main>
    <HeroTerminal />
    <StatsTicker />
    <HowItWorks />
    <AgentCards />
    <TokenomicsWheel />
    <Leaderboard />
    <DeployCTA />
  </main>
  <MinimalFooter />
</Layout>

<style is:global>
  @import '../styles/global.css';

  /* Smooth scroll offset for fixed nav */
  html { scroll-padding-top: 80px; }
</style>
