---
---
<!-- Sticky tokenomics section -->
<div class="tokenomics-sticky-outer" id="tokenomics-sticky-outer">
  <section class="tokenomics-section" id="tokenomics">
    <div class="container">
      <div class="tokenomics-grid">
        <!-- Left: Copy with staged reveals -->
        <div class="tokenomics-copy">
          <div class="reveal-mask">
            <div class="section-label reveal-text" id="tok-label">Tokenomics</div>
          </div>
          <div class="reveal-mask">
            <h2 class="section-title reveal-text" id="tok-title">
              Every Trade Feeds<br><span class="text-gradient">The Flywheel</span>
            </h2>
          </div>
          <div class="reveal-mask">
            <p class="tokenomics-desc reveal-text" id="tok-desc">
              Every revenue stream in OpenTrade creates continuous buy pressure on $OT.
              Agent trading fees, agent token fees, plugin marketplace sales, profit buybacks  - 
              all roads lead to the OpenTrade token.
            </p>
          </div>

          <div class="tokenomics-flows">
            <div class="flow-item" id="flow-1">
              <div class="flow-icon" style="color:#ffffff;background:rgba(255,255,255,0.05);border:1px solid #333333">
              <span class="pixel-icon" style="font-size:1.5rem">$</span>
            </div>
              <div class="flow-content">
                <div class="flow-title">Platform Trading Fee</div>
                <div class="flow-desc">0.5% fee on every agent trade. 80% used to buy back $OT token. 20% funds team operations.</div>
              </div>
              <div class="flow-progress">
                <div class="flow-bar flow-bar-1"></div>
              </div>
            </div>
            <div class="flow-item" id="flow-2">
              <div class="flow-icon" style="color:var(--green);background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3)">
                <svg width="16" height="16" viewBox="0 0 82.5 82.5" fill="none"><circle cx="35.8" cy="2.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="8.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="8.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="8.2" r="2.3" fill="currentColor"/><circle cx="24.8" cy="13.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="13.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="13.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="13.8" r="2.3" fill="currentColor"/><circle cx="46.8" cy="13.8" r="2.3" fill="currentColor"/><circle cx="19.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="24.8" cy="19.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="19.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="46.8" cy="19.2" r="2.3" fill="currentColor"/><circle cx="52.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="13.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="19.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="24.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="46.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="52.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="57.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="8.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="13.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="19.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="24.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="46.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="52.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="57.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="63.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="2.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="8.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="13.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="19.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="24.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="46.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="52.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="57.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="63.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="68.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="41.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="41.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="41.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="46.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="46.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="46.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="52.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="52.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="52.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="57.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="57.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="57.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="63.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="63.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="63.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="68.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="68.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="68.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="74.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="74.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="74.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="79.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="79.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="79.8" r="2.3" fill="currentColor"/></svg>
              </div>
              <div class="flow-content">
                <div class="flow-title">Agent Token Fees</div>
                <div class="flow-desc">Agent tokens generate trading fees split 80/20. 80% compounds into the agent wallet, 20% buys back $OT.</div>
              </div>
              <div class="flow-progress">
                <div class="flow-bar flow-bar-2"></div>
              </div>
            </div>
            <div class="flow-item" id="flow-3">
              <div class="flow-icon" style="color:#ffffff;background:rgba(255,255,255,0.05);border:1px solid #333333">
                <span class="pixel-icon" style="font-size:1.5rem">✕</span>
              </div>
              <div class="flow-content">
                <div class="flow-title">Marketplace Revenue</div>
                <div class="flow-desc">Protocol takes 20% of all plugin marketplace sales. 100% of that cut goes to $OT buybacks.</div>
              </div>
              <div class="flow-progress">
                <div class="flow-bar flow-bar-3"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Wheel diagram with scrubbed rotation -->
        <div class="tokenomics-wheel-wrapper">
          <div class="wheel-container" id="flywheel">
            <!-- Central hub -->
            <div class="wheel-center" id="wheel-center">
              <div class="wheel-center-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              </div>
              <div class="wheel-center-label mono">TOKEN</div>
            </div>

            <!-- Ring nodes -->
            <div class="wheel-node node-top" id="node-fees">
              <div class="node-icon">
                <span class="pixel-icon" style="font-size:1.3rem">$</span>
              </div>
              <div class="node-label">Trading Fees</div>
            </div>

            <div class="wheel-node node-right" id="node-buyback">
              <div class="node-icon">
                <span class="pixel-icon" style="font-size:1.3rem">↻</span>
              </div>
              <div class="node-label">Buyback</div>
            </div>

            <div class="wheel-node node-bottom" id="node-burn">
              <div class="node-icon">
                <span class="pixel-icon" style="font-size:1.3rem">✕</span>
              </div>
              <div class="node-label">Burn</div>
            </div>

            <div class="wheel-node node-left" id="node-value">
              <div class="node-icon">
                <span class="pixel-icon" style="font-size:1.3rem">↑</span>
              </div>
              <div class="node-label">Token Value</div>
            </div>

            <!-- SVG arrows (the rotating ring) -->
            <svg class="wheel-svg" id="wheel-svg" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <marker id="arrow-cyan" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L6,3 z" fill="#666666"/>
                </marker>
                <marker id="arrow-green" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L6,3 z" fill="#22c55e"/>
                </marker>
                <marker id="arrow-purple" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L6,3 z" fill="#888888"/>
                </marker>
                <filter id="glow-filter">
                  <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                  <feMerge>
                    <feMergeNode in="coloredBlur"/>
                    <feMergeNode in="SourceGraphic"/>
                  </feMerge>
                </filter>
              </defs>

              <!-- Base ring -->
              <circle cx="150" cy="150" r="100" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1" stroke-dasharray="4 4"/>

              <!-- Arc segments -->
              <path d="M 150 50 A 100 100 0 0 1 250 150" fill="none" stroke="#666666" stroke-width="2"
                stroke-dasharray="8 4" marker-end="url(#arrow-cyan)" filter="url(#glow-filter)" opacity="0.9"/>
              <path d="M 250 150 A 100 100 0 0 1 150 250" fill="none" stroke="#22c55e" stroke-width="2"
                stroke-dasharray="8 4" marker-end="url(#arrow-green)" filter="url(#glow-filter)" opacity="0.9"/>
              <path d="M 150 250 A 100 100 0 0 1 50 150" fill="none" stroke="#888888" stroke-width="2"
                stroke-dasharray="8 4" marker-end="url(#arrow-purple)" filter="url(#glow-filter)" opacity="0.9"/>
              <path d="M 50 150 A 100 100 0 0 1 150 50" fill="none" stroke="#666666" stroke-width="2"
                stroke-dasharray="8 4" marker-end="url(#arrow-cyan)" filter="url(#glow-filter)" opacity="0.9"/>
            </svg>
          </div>

          <!-- Token supply breakdown with animated bars -->
          <div class="supply-bar-section">
            <div class="supply-title mono">Token Allocation</div>
            <div class="supply-bars">
              <div class="supply-item">
                <div class="supply-label">Trading Pool</div>
                <div class="supply-bar-wrap">
                  <div class="supply-bar supply-bar-anim" data-width="40" style="background:var(--cyan)"></div>
                </div>
                <div class="supply-pct mono">40%</div>
              </div>
              <div class="supply-item">
                <div class="supply-label">Buyback Reserve</div>
                <div class="supply-bar-wrap">
                  <div class="supply-bar supply-bar-anim" data-width="30" style="background:var(--green)"></div>
                </div>
                <div class="supply-pct mono">30%</div>
              </div>
              <div class="supply-item">
                <div class="supply-label">Team / Dev</div>
                <div class="supply-bar-wrap">
                  <div class="supply-bar supply-bar-anim" data-width="15" style="background:var(--purple)"></div>
                </div>
                <div class="supply-pct mono">15%</div>
              </div>
              <div class="supply-item">
                <div class="supply-label">Community</div>
                <div class="supply-bar-wrap">
                  <div class="supply-bar supply-bar-anim" data-width="15" style="background:#FFE600"></div>
                </div>
                <div class="supply-pct mono">15%</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .tokenomics-sticky-outer {
    position: relative;
  }

  .tokenomics-section {
    padding: var(--space-3xl) 0;
    position: relative;
    background: var(--bg-surface);
    border-top: 1px solid var(--bg-border);
    border-bottom: 1px solid var(--bg-border);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .tokenomics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .tokenomics-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    margin: 1.25rem 0 2rem;
  }

  /* Flows */
  .tokenomics-flows {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .flow-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    opacity: 0;
    transform: translateX(-30px);
    position: relative;
    padding: 1rem 1.25rem;
    border-radius: 0;
    background: rgba(0,0,0,0.15);
    border: 1px solid #222222;
  }

  .flow-icon {
    width: 44px;
    height: 44px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .flow-title { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.25rem; }
  .flow-desc { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }

  .flow-content { flex: 1; }

  .flow-progress {
    position: absolute;
    bottom: -8px;
    left: 56px;
    right: 0;
    height: 2px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
  }

  .flow-bar {
    height: 100%;
    width: 0%;
    border-radius: 2px;
    transition: width 1s ease;
  }

  .flow-bar-1 { background: var(--cyan); }
  .flow-bar-2 { background: var(--green); }
  .flow-bar-3 { background: var(--purple); }

  /* Wheel */
  .tokenomics-wheel-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .wheel-container {
    position: relative;
    width: 300px;
    height: 300px;
    margin: 0 auto;
  }

  .wheel-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform-origin: center center;
    will-change: transform;
  }

  .wheel-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border-radius: 0;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid #444444;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
    will-change: transform;
  }

  .wheel-center-icon { display: flex; align-items: center; justify-content: center; color: var(--cyan); }
  .wheel-center-label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em; color: var(--cyan); }

  .wheel-node {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    width: 64px;
    z-index: 3;
    transition: all 0.4s ease;
  }

  .node-icon { display: flex; align-items: center; justify-content: center; color: var(--cyan); }
  .node-label { font-size: 0.65rem; font-family: var(--font-mono); font-weight: 600; color: var(--text-secondary); text-align: center; line-height: 1.2; }

  .node-top    { top: 0; left: 50%; transform: translateX(-50%); }
  .node-right  { right: 0; top: 50%; transform: translateY(-50%); }
  .node-bottom { bottom: 0; left: 50%; transform: translateX(-50%); }
  .node-left   { left: 0; top: 50%; transform: translateY(-50%); }

  .wheel-node.active .node-icon {
    filter: drop-shadow(0 0 8px var(--cyan));
    transform: scale(1.2);
  }

  /* Supply bars */
  .supply-bar-section {
    background: var(--bg-card);
    border: 1px solid #222222;
    border-radius: 0;
    padding: 1.25rem;
  }

  .supply-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .supply-bars { display: flex; flex-direction: column; gap: 0.75rem; }

  .supply-item {
    display: grid;
    grid-template-columns: 130px 1fr 40px;
    align-items: center;
    gap: 0.75rem;
  }

  .supply-label { font-size: 0.8rem; color: var(--text-secondary); }

  .supply-bar-wrap {
    height: 8px;
    background: var(--bg-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .supply-bar {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .supply-pct { font-size: 0.78rem; font-weight: 700; color: var(--text-primary); text-align: right; }

  @media (max-width: 900px) {
    .tokenomics-grid { grid-template-columns: 1fr; }
    .wheel-container { margin: 0 auto; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─── Header reveals ─────────────────────────────────
  gsap.set(['#tok-label', '#tok-title', '#tok-desc'], { y: 50, opacity: 0 });

  ScrollTrigger.create({
    trigger: '.tokenomics-section',
    start: 'top 75%',
    onEnter: () => {
      gsap.to('#tok-label', { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' });
      gsap.to('#tok-title', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.1 });
      gsap.to('#tok-desc', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.2 });

      // Flow items slide in with stagger
      gsap.to(['#flow-1', '#flow-2', '#flow-3'], {
        x: 0,
        opacity: 1,
        duration: 0.7,
        stagger: 0.2,
        ease: 'power3.out',
        delay: 0.4,
        onComplete: () => {
          // Fill flow progress bars
          document.querySelectorAll('.flow-bar').forEach((bar, i) => {
            setTimeout(() => {
              (bar as HTMLElement).style.width = '100%';
            }, i * 200);
          });
        }
      });

      // Supply bars fill
      setTimeout(() => {
        document.querySelectorAll('.supply-bar-anim').forEach(bar => {
          const width = bar.getAttribute('data-width') || '0';
          (bar as HTMLElement).style.width = `${width}%`;
        });
      }, 800);
    }
  });

  // ─── Scrubbed flywheel rotation ──────────────────────
  // The SVG ring rotates based on scroll progress
  gsap.to('#wheel-svg', {
    rotation: 360,
    transformOrigin: '150px 150px', // SVG viewBox center
    ease: 'none',
    scrollTrigger: {
      trigger: '.tokenomics-section',
      start: 'top 60%',
      end: 'bottom 40%',
      scrub: 2,
    }
  });

  // Wheel center pulsing glow (CSS-driven but enhanced)
  gsap.to('#wheel-center', {
    borderColor: '#666666',
    duration: 1.5,
    repeat: -1,
    yoyo: true,
    ease: 'power1.inOut',
  });

  // Node activation sequence based on scroll
  const nodes = ['#node-fees', '#node-buyback', '#node-burn', '#node-value'];
  
  ScrollTrigger.create({
    trigger: '.tokenomics-section',
    start: 'top 60%',
    end: 'bottom 40%',
    scrub: 1,
    onUpdate: (self) => {
      const progress = self.progress;
      const activeIdx = Math.floor(progress * 4);
      nodes.forEach((sel, i) => {
        const el = document.querySelector(sel);
        if (el) {
          el.classList.toggle('active', i === activeIdx);
        }
      });
    }
  });
</script>
