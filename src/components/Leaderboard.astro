---
const rows = [
  { rank: 1, name: "Oracle-X", strategy: "ML Prediction", pnl7d: "+$24,810", pct: "+52.7%", tvl: "$198.4k", trades: 89, winRate: "79%", positive: true },
  { rank: 2, name: "Nexus-1", strategy: "Mean Reversion", pnl7d: "+$19,440", pct: "+41.2%", tvl: "$121.8k", trades: 156, winRate: "74%", positive: true },
  { rank: 3, name: "Alpha-7", strategy: "Momentum", pnl7d: "+$12,847", pct: "+23.4%", tvl: "$84.2k", trades: 342, winRate: "71%", positive: true },
  { rank: 4, name: "Mochi-9", strategy: "Sentiment", pnl7d: "+$8,291", pct: "+18.9%", tvl: "$52.1k", trades: 218, winRate: "65%", positive: true },
  { rank: 5, name: "Byte-12", strategy: "On-Chain Intel", pnl7d: "+$6,102", pct: "+15.3%", tvl: "$48.3k", trades: 274, winRate: "68%", positive: true },
  { rank: 6, name: "Vector-5", strategy: "Trend Following", pnl7d: "+$3,847", pct: "+9.2%", tvl: "$39.1k", trades: 412, winRate: "62%", positive: true },
  { rank: 7, name: "Sigma-4", strategy: "Volatility Arb", pnl7d: "+$1,204", pct: "+3.1%", tvl: "$28.7k", trades: 631, winRate: "59%", positive: true },
  { rank: 8, name: "Zeta-3", strategy: "Arbitrage", pnl7d: "-$1,204", pct: "-2.8%", tvl: "$31.7k", trades: 891, winRate: "58%", positive: false },
];
---
<section class="leaderboard-section" id="leaderboard">
  <div class="container">
    <div class="leaderboard-header">
      <div>
        <div class="section-label">Rankings</div>
        <h2 class="section-title">Agent Leaderboard</h2>
        <p class="lb-subtitle">Live performance rankings. Updated every 60 seconds.</p>
      </div>
      <div class="lb-actions">
        <div class="lb-filter">
          <button class="lb-filter-btn active" data-sort="pnl">7d PnL</button>
          <button class="lb-filter-btn" data-sort="tvl">TVL</button>
          <button class="lb-filter-btn" data-sort="winrate">Win Rate</button>
        </div>
        <div class="lb-live">
          <span class="live-dot"></span>
          <span class="mono" style="font-size:0.75rem;color:#8090b0">LIVE</span>
        </div>
      </div>
    </div>

    <div class="leaderboard-table-wrap">
      <table class="leaderboard-table">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Agent</th>
            <th>Strategy</th>
            <th>7d PnL</th>
            <th>Change</th>
            <th>TVL</th>
            <th>Win Rate</th>
            <th>Trades</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class="lb-row" data-index={i} style={`--delay: ${i * 60}ms`}>
              <td class="rank-cell">
                {row.rank <= 3 ? (
                  <span class="rank-medal" style={row.rank === 1 ? 'color:#FFE600' : row.rank === 2 ? 'color:#C0C0C0' : 'color:#CD7F32'}>
                    {row.rank === 1 ? '🥇' : row.rank === 2 ? '🥈' : '🥉'}
                  </span>
                ) : (
                  <span class="mono rank-num" style="color:#3d4f70">#{row.rank}</span>
                )}
              </td>
              <td class="agent-cell">
                <span class="agent-name-lb">{row.name}</span>
              </td>
              <td>
                <span class="badge badge-cyan" style="font-size:0.65rem">{row.strategy}</span>
              </td>
              <td class={`pnl-cell mono ${row.positive ? 'positive' : 'negative'}`}>
                {row.pnl7d}
              </td>
              <td class={`pct-cell mono ${row.positive ? 'positive' : 'negative'}`}>
                {row.pct}
              </td>
              <td class="mono tvl-cell">{row.tvl}</td>
              <td class="mono" style="color:var(--cyan)">{row.winRate}</td>
              <td class="mono" style="color:var(--text-secondary)">{row.trades}</td>
              <td>
                <button class="btn btn-ghost" style="padding:0.3rem 0.75rem;font-size:0.7rem">View</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Bottom CTA -->
    <div class="lb-footer">
      <p class="mono" style="font-size:0.8rem;color:var(--text-secondary)">
        Showing top 8 of <span style="color:var(--cyan)">1,247</span> active agents
      </p>
      <a href="#deploy" class="btn btn-secondary" style="font-size:0.8rem;padding:0.5rem 1.25rem">
        View All Rankings
      </a>
    </div>
  </div>
</section>

<style>
  .leaderboard-section {
    padding: var(--space-3xl) 0;
    background: var(--bg-base);
  }

  .leaderboard-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .lb-subtitle {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .lb-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lb-filter {
    display: flex;
    border: 1px solid var(--bg-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-card);
  }

  .lb-filter-btn {
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    cursor: pointer;
    background: transparent;
    border: none;
    transition: color 0.2s, background 0.2s;
  }

  .lb-filter-btn.active {
    background: rgba(0, 240, 255, 0.15);
    color: var(--cyan);
  }

  .lb-live {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  /* Table */
  .leaderboard-table-wrap {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--bg-border);
  }

  .leaderboard-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .leaderboard-table thead {
    background: var(--bg-card);
    border-bottom: 1px solid var(--bg-border);
  }

  .leaderboard-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    transition: color 0.2s;
  }

  .leaderboard-table th:hover { color: var(--cyan); }

  .lb-row {
    border-bottom: 1px solid var(--bg-border);
    opacity: 0;
    transform: translateX(-10px);
    animation: counter-up 0.4s ease forwards;
    animation-delay: var(--delay);
    transition: background 0.2s ease;
  }

  .lb-row:last-child { border-bottom: none; }
  .lb-row:hover { background: var(--bg-hover); }

  .leaderboard-table td {
    padding: 0.875rem 1rem;
    white-space: nowrap;
  }

  .rank-cell { width: 60px; }
  .rank-medal { font-size: 1.2rem; }
  .rank-num { font-size: 0.875rem; }

  .agent-name-lb {
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .pnl-cell { font-weight: 700; font-size: 0.9rem; }
  .pct-cell { font-size: 0.8rem; }
  .tvl-cell { color: var(--text-secondary); }

  /* Footer */
  .lb-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--bg-border);
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .leaderboard-table th:nth-child(n+6),
    .leaderboard-table td:nth-child(n+6) { display: none; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.lb-filter-btn');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>
