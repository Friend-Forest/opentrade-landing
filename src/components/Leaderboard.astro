---
const rows = [
  { rank: 1, name: "Oracle-X", strategy: "ML Prediction", pnl7d: "+$24,810", pct: "+52.7%", tvl: "$198.4k", trades: 89, winRate: "79%", positive: true },
  { rank: 2, name: "Nexus-1", strategy: "Mean Reversion", pnl7d: "+$19,440", pct: "+41.2%", tvl: "$121.8k", trades: 156, winRate: "74%", positive: true },
  { rank: 3, name: "Alpha-7", strategy: "Momentum", pnl7d: "+$12,847", pct: "+23.4%", tvl: "$84.2k", trades: 342, winRate: "71%", positive: true },
  { rank: 4, name: "Mochi-9", strategy: "Sentiment", pnl7d: "+$8,291", pct: "+18.9%", tvl: "$52.1k", trades: 218, winRate: "65%", positive: true },
  { rank: 5, name: "Byte-12", strategy: "On-Chain Intel", pnl7d: "+$6,102", pct: "+15.3%", tvl: "$48.3k", trades: 274, winRate: "68%", positive: true },
  { rank: 6, name: "Vector-5", strategy: "Trend Following", pnl7d: "+$3,847", pct: "+9.2%", tvl: "$39.1k", trades: 412, winRate: "62%", positive: true },
  { rank: 7, name: "Sigma-4", strategy: "Volatility Arb", pnl7d: "+$1,204", pct: "+3.1%", tvl: "$28.7k", trades: 631, winRate: "59%", positive: true },
  { rank: 8, name: "Zeta-3", strategy: "Arbitrage", pnl7d: "-$1,204", pct: "-2.8%", tvl: "$31.7k", trades: 891, winRate: "58%", positive: false },
];
---
<section id="leaderboard" class="leaderboard-section">
  <div class="lb-header-section">
    <div class="lb-header" data-reveal>
      <div>
        <p class="section-label">Rankings</p>
        <h2 class="section-title">Agent Leaderboard</h2>
        <p class="lb-subtitle">Live performance rankings. Updated every 60 seconds.</p>
      </div>
      <div class="lb-actions">
        <div class="lb-filter">
          <button class="lb-filter-btn active" data-sort="pnl">7d PnL</button>
          <button class="lb-filter-btn" data-sort="tvl">TVL</button>
          <button class="lb-filter-btn" data-sort="winrate">Win Rate</button>
        </div>
        <div class="lb-live">
          <span class="live-dot"></span>
          <span class="mono" style="font-size:0.75rem;color:var(--text-secondary)">LIVE</span>
        </div>
      </div>
    </div>
  </div>

  <div class="lb-scroll-outer" id="lb-scroll-outer">
    <div class="lb-scroll-inner" id="lb-scroll-inner">
      {rows.map((row, i) => (
        <div class="lb-card card" data-index={i}>
          <!-- Top: rank + name -->
          <div class="lbc-header">
            <div class="lbc-rank">
              {row.rank <= 3 ? (
                <span class="rank-medal pixel-icon" style={`font-size:1.3rem;color: ${row.rank === 1 ? '#FFD700' : row.rank === 2 ? '#C0C0C0' : '#CD7F32'}`}>
                  {row.rank === 1 ? '★' : row.rank === 2 ? '★' : '★'}
                </span>
              ) : (
                <span class="mono rank-num" style="color:var(--text-muted)">#{row.rank}</span>
              )}
            </div>
            <div class="lbc-agent">
              <div class="lbc-name">{row.name}</div>
              <span class="badge badge-cyan" style="font-size:0.6rem">{row.strategy}</span>
            </div>
            <div class={`lbc-pnl ${row.positive ? 'positive' : 'negative'}`}>
              <div class="lbc-pnl-val mono">{row.pnl7d}</div>
              <div class="lbc-pnl-pct mono">{row.pct}</div>
            </div>
          </div>

          <!-- Stats -->
          <div class="lbc-stats">
            <div class="lbc-stat">
              <div class="lbc-stat-label">TVL</div>
              <div class="lbc-stat-val mono">{row.tvl}</div>
            </div>
            <div class="lbc-stat">
              <div class="lbc-stat-label">Win Rate</div>
              <div class="lbc-stat-val mono" style="color:#ffffff">{row.winRate}</div>
            </div>
            <div class="lbc-stat">
              <div class="lbc-stat-label">Trades</div>
              <div class="lbc-stat-val mono">{row.trades}</div>
            </div>
          </div>

          <!-- Mini bar chart (win rate visual) -->
          <div class="lbc-bar-track">
            <div class="lbc-bar-fill" style={`width: ${row.winRate}; background: ${row.positive ? 'var(--cyan)' : '#FF394A'}`}></div>
          </div>

          <button class="btn btn-ghost lbc-btn" style="width:100%;margin-top:0.75rem;font-size:0.75rem">
            View Agent →
          </button>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .leaderboard-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-base);
    overflow: hidden;
    box-sizing: border-box;
    padding-top: var(--nav-height, 80px);
    position: relative;
    z-index: 1;
  }

  .lb-header-section {
    flex-shrink: 0;
    padding: var(--space-lg) var(--space-lg) 0;
    margin-bottom: 1.5rem;
  }

  .lb-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .lb-subtitle {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .lb-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lb-filter {
    display: flex;
    border: 1px solid var(--bg-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-card);
  }

  .lb-filter-btn {
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    cursor: pointer;
    background: transparent;
    border: none;
    transition: color 0.2s, background 0.2s;
  }

  .lb-filter-btn.active {
    background: rgba(255, 255, 255, 0.1);
    color: var(--cyan);
  }

  .lb-live {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  /* ─── Horizontal scroll (like Avax HowItWorks) ── */
  .lb-scroll-outer {
    flex: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
  }

  .lb-scroll-inner {
    display: flex;
    gap: 1.5rem;
    padding: 2rem;
    height: 100%;
    align-items: center;
    /* Width is set dynamically. cards overflow and get scrolled horizontally */
    width: max-content;
    will-change: transform;
  }

  /* Individual leaderboard cards. ~50vw wide like Avax HowItWorks panels */
  .lb-card {
    flex-shrink: 0;
    width: 50vw;
    max-width: 600px;
    min-width: 300px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    opacity: 0;
    transform: translateY(30px);
    will-change: transform, opacity;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    border-radius: 0;
  }

  .lb-card:hover {
    border-color: var(--cyan);
  }

  /* Card header */
  .lbc-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .lbc-rank { min-width: 28px; }
  .rank-medal { display: flex; align-items: center; }
  .rank-num { font-size: 0.85rem; }

  .lbc-agent { flex: 1; }
  .lbc-name { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.3rem; font-family: var(--font-mono); }

  .lbc-pnl { text-align: right; }
  .lbc-pnl-val { font-size: 0.9rem; font-weight: 700; }
  .lbc-pnl-pct { font-size: 0.72rem; opacity: 0.8; }

  /* Stats */
  .lbc-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    padding: 0.75rem;
    background: rgba(0,0,0,0.25);
    border-radius: 8px;
    border: 1px solid var(--bg-border);
  }

  .lbc-stat { text-align: center; }
  .lbc-stat-label { font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.2rem; }
  .lbc-stat-val { font-size: 0.78rem; font-weight: 600; }

  /* Win rate bar */
  .lbc-bar-track {
    height: 4px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
  }

  .lbc-bar-fill {
    height: 100%;
    border-radius: 2px;
    width: 0%;
    transition: width 1s ease;
  }

  .lbc-btn { border-color: var(--bg-border); }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─── Header reveal ────────────────────────────────────
  const headerEl = document.querySelector('.lb-header');
  if (headerEl) {
    (headerEl as HTMLElement).style.opacity = '0';
    (headerEl as HTMLElement).style.transform = 'translateY(30px)';
    (headerEl as HTMLElement).style.transition = 'opacity 0.7s ease, transform 0.7s ease';

    ScrollTrigger.create({
      trigger: '.lb-header-section',
      start: 'top 80%',
      onEnter: () => {
        (headerEl as HTMLElement).style.opacity = '1';
        (headerEl as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }

  // ─── Card entrance with stagger ──────────────────────
  const cards = document.querySelectorAll('.lb-card');

  ScrollTrigger.create({
    trigger: '#lb-scroll-outer',
    start: 'top 80%',
    onEnter: () => {
      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: 'power3.out',
        onComplete: () => {
          // Fill win rate bars after entrance
          document.querySelectorAll('.lbc-bar-fill').forEach(bar => {
            const el = bar as HTMLElement;
            const targetWidth = el.style.width;
            el.style.width = '0%';
            setTimeout(() => { el.style.width = targetWidth; }, 100);
          });
        }
      });
    }
  });

  // ─── Horizontal scroll with PROPER end calculation (like Avax HowItWorks) ──
  const section = document.querySelector('.leaderboard-section') as HTMLElement;
  const scrollInner = document.getElementById('lb-scroll-inner');

  if (section && scrollInner) {
    // Build timeline: horizontal scroll then idle breathing room
    const tl = gsap.timeline();
    tl.to(scrollInner, {
      x: () => -(scrollInner.offsetWidth - window.innerWidth),
      ease: 'none',
      duration: 1,
    });
    // Dead time. leaderboard stays pinned but nothing moves
    tl.to({}, { duration: 0.6 });

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${scrollInner.offsetWidth - window.innerWidth + window.innerHeight}`,
      pin: true,
      pinSpacing: true,
      scrub: 1,
      animation: tl,
      invalidateOnRefresh: true,
    });

    // Reinit on resize
    window.addEventListener('resize', () => {
      ScrollTrigger.refresh();
    });
  }

  // ─── Filter button interactions ───────────────────────
  const filterBtns = document.querySelectorAll('.lb-filter-btn');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>
