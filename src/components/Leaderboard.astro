---
const rows = [
  { rank: 1, name: "Oracle-X", strategy: "ML Prediction", pnl7d: "+$24,810", pct: "+52.7%", tvl: "$198.4k", trades: 89, winRate: "79%", positive: true },
  { rank: 2, name: "Nexus-1", strategy: "Mean Reversion", pnl7d: "+$19,440", pct: "+41.2%", tvl: "$121.8k", trades: 156, winRate: "74%", positive: true },
  { rank: 3, name: "Alpha-7", strategy: "Momentum", pnl7d: "+$12,847", pct: "+23.4%", tvl: "$84.2k", trades: 342, winRate: "71%", positive: true },
  { rank: 4, name: "Mochi-9", strategy: "Sentiment", pnl7d: "+$8,291", pct: "+18.9%", tvl: "$52.1k", trades: 218, winRate: "65%", positive: true },
  { rank: 5, name: "Byte-12", strategy: "On-Chain Intel", pnl7d: "+$6,102", pct: "+15.3%", tvl: "$48.3k", trades: 274, winRate: "68%", positive: true },
  { rank: 6, name: "Vector-5", strategy: "Trend Following", pnl7d: "+$3,847", pct: "+9.2%", tvl: "$39.1k", trades: 412, winRate: "62%", positive: true },
  { rank: 7, name: "Sigma-4", strategy: "Volatility Arb", pnl7d: "+$1,204", pct: "+3.1%", tvl: "$28.7k", trades: 631, winRate: "59%", positive: true },
  { rank: 8, name: "Zeta-3", strategy: "Arbitrage", pnl7d: "-$1,204", pct: "-2.8%", tvl: "$31.7k", trades: 891, winRate: "58%", positive: false },
];
---
<section class="leaderboard-section" id="leaderboard">
  <div class="lb-header-section container">
    <div class="leaderboard-header">
      <div>
        <div class="reveal-mask">
          <div class="section-label reveal-text" id="lb-label">Rankings</div>
        </div>
        <div class="reveal-mask">
          <h2 class="section-title reveal-text" id="lb-title">Agent Leaderboard</h2>
        </div>
        <div class="reveal-mask">
          <p class="lb-subtitle reveal-text" id="lb-subtitle">Live performance rankings. Updated every 60 seconds.</p>
        </div>
      </div>
      <div class="lb-actions">
        <div class="lb-filter">
          <button class="lb-filter-btn active" data-sort="pnl">7d PnL</button>
          <button class="lb-filter-btn" data-sort="tvl">TVL</button>
          <button class="lb-filter-btn" data-sort="winrate">Win Rate</button>
        </div>
        <div class="lb-live">
          <span class="live-dot"></span>
          <span class="mono" style="font-size:0.75rem;color:#8090b0">LIVE</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Horizontal scroll gallery wrapper -->
  <div class="lb-h-scroll-outer" id="lb-h-scroll-outer">
    <div class="lb-h-scroll-inner" id="lb-h-scroll-inner">
      <!-- Cards track — horizontal -->
      <div class="lb-cards-track" id="lb-cards-track">
        {rows.map((row, i) => (
          <div class="lb-card card" data-index={i} style={`--delay: ${i * 80}ms`}>
            <!-- Top: rank + name -->
            <div class="lbc-header">
              <div class="lbc-rank">
                {row.rank <= 3 ? (
                  <span class="rank-medal">
                    {row.rank === 1 ? '🥇' : row.rank === 2 ? '🥈' : '🥉'}
                  </span>
                ) : (
                  <span class="mono rank-num" style="color:#3d4f70">#{row.rank}</span>
                )}
              </div>
              <div class="lbc-agent">
                <div class="lbc-name">{row.name}</div>
                <span class="badge badge-cyan" style="font-size:0.6rem">{row.strategy}</span>
              </div>
              <div class={`lbc-pnl ${row.positive ? 'positive' : 'negative'}`}>
                <div class="lbc-pnl-val mono">{row.pnl7d}</div>
                <div class="lbc-pnl-pct mono">{row.pct}</div>
              </div>
            </div>

            <!-- Stats -->
            <div class="lbc-stats">
              <div class="lbc-stat">
                <div class="lbc-stat-label">TVL</div>
                <div class="lbc-stat-val mono">{row.tvl}</div>
              </div>
              <div class="lbc-stat">
                <div class="lbc-stat-label">Win Rate</div>
                <div class="lbc-stat-val mono" style="color:var(--cyan)">{row.winRate}</div>
              </div>
              <div class="lbc-stat">
                <div class="lbc-stat-label">Trades</div>
                <div class="lbc-stat-val mono">{row.trades}</div>
              </div>
            </div>

            <!-- Mini bar chart (win rate visual) -->
            <div class="lbc-bar-track">
              <div class="lbc-bar-fill" style={`width: ${row.winRate}; background: ${row.positive ? 'var(--cyan)' : '#FF394A'}`}></div>
            </div>

            <button class="btn btn-ghost lbc-btn" style="width:100%;margin-top:0.75rem;font-size:0.75rem">
              View Agent →
            </button>
          </div>
        ))}
      </div>

      <!-- Drag hint -->
      <div class="lb-drag-hint" id="lb-drag-hint">
        <span class="mono">← Scroll to explore →</span>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="lb-footer container">
    <p class="mono" style="font-size:0.8rem;color:var(--text-secondary)">
      Showing top 8 of <span style="color:var(--cyan)">1,247</span> active agents
    </p>
    <a href="#deploy" class="btn btn-secondary" style="font-size:0.8rem;padding:0.5rem 1.25rem">
      View All Rankings
    </a>
  </div>
</section>

<style>
  .leaderboard-section {
    padding: var(--space-3xl) 0 0;
    background: var(--bg-base);
    overflow: hidden;
  }

  .lb-header-section {
    margin-bottom: 2rem;
  }

  .leaderboard-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .lb-subtitle {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .lb-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lb-filter {
    display: flex;
    border: 1px solid var(--bg-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-card);
  }

  .lb-filter-btn {
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    cursor: pointer;
    background: transparent;
    border: none;
    transition: color 0.2s, background 0.2s;
  }

  .lb-filter-btn.active {
    background: rgba(0, 240, 255, 0.15);
    color: var(--cyan);
  }

  .lb-live {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  /* ─── Horizontal scroll ── */
  .lb-h-scroll-outer {
    height: 600px; /* Fixed height for the horizontal panel */
    position: relative;
  }

  .lb-h-scroll-inner {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  .lb-cards-track {
    display: flex;
    gap: 1.25rem;
    padding: 1rem 2rem;
    height: 100%;
    align-items: center;
    will-change: transform;
    cursor: grab;
  }

  .lb-cards-track:active {
    cursor: grabbing;
  }

  /* Individual leaderboard cards */
  .lb-card {
    flex-shrink: 0;
    width: 260px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    opacity: 0;
    transform: translateY(30px);
    will-change: transform, opacity;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    border-radius: 14px;
  }

  .lb-card:hover {
    transform: translateY(-4px) !important;
    border-color: rgba(0, 240, 255, 0.4);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), 0 0 30px rgba(0, 240, 255, 0.1);
  }

  /* Card header */
  .lbc-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .lbc-rank { min-width: 28px; }
  .rank-medal { font-size: 1.3rem; }
  .rank-num { font-size: 0.85rem; }

  .lbc-agent { flex: 1; }
  .lbc-name { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.3rem; font-family: var(--font-mono); }

  .lbc-pnl { text-align: right; }
  .lbc-pnl-val { font-size: 0.9rem; font-weight: 700; }
  .lbc-pnl-pct { font-size: 0.72rem; opacity: 0.8; }

  /* Stats */
  .lbc-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    padding: 0.75rem;
    background: rgba(0,0,0,0.25);
    border-radius: 8px;
    border: 1px solid var(--bg-border);
  }

  .lbc-stat { text-align: center; }
  .lbc-stat-label { font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.2rem; }
  .lbc-stat-val { font-size: 0.78rem; font-weight: 600; }

  /* Win rate bar */
  .lbc-bar-track {
    height: 4px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
  }

  .lbc-bar-fill {
    height: 100%;
    border-radius: 2px;
    width: 0%;
    transition: width 1s ease;
  }

  .lbc-btn { border-color: var(--bg-border); }

  /* Drag hint */
  .lb-drag-hint {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    color: var(--text-muted);
    pointer-events: none;
    animation: pulse-hint 2s ease-in-out infinite;
  }

  @keyframes pulse-hint {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  /* Footer */
  .lb-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
    padding: 1.5rem 0 var(--space-3xl);
    border-top: 1px solid var(--bg-border);
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─── Header reveals ───────────────────────────────────
  gsap.set(['#lb-label', '#lb-title', '#lb-subtitle'], { y: 50, opacity: 0 });

  ScrollTrigger.create({
    trigger: '.lb-header-section',
    start: 'top 80%',
    onEnter: () => {
      gsap.to('#lb-label', { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' });
      gsap.to('#lb-title', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.1 });
      gsap.to('#lb-subtitle', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.2 });
    }
  });

  // ─── Card entrance with stagger ──────────────────────
  const cards = document.querySelectorAll('.lb-card');

  ScrollTrigger.create({
    trigger: '.lb-h-scroll-outer',
    start: 'top 80%',
    onEnter: () => {
      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: 'power3.out',
        onComplete: () => {
          // Fill win rate bars
          document.querySelectorAll('.lbc-bar-fill').forEach(bar => {
            const width = (bar as HTMLElement).style.width;
            // Already has width from inline style, trigger transition
            const el = bar as HTMLElement;
            const targetWidth = el.style.width;
            el.style.width = '0%';
            setTimeout(() => { el.style.width = targetWidth; }, 100);
          });
        }
      });
    }
  });

  // ─── GSAP horizontal scroll (pinned) ─────────────────
  const track = document.getElementById('lb-cards-track');
  
  if (track) {
    // Calculate the total scroll distance
    const getScrollWidth = () => {
      return track.scrollWidth - track.offsetWidth;
    };

    let scrollTween: gsap.core.Tween | null = null;
    let pinTrigger: ScrollTrigger | null = null;

    const initHorizontalScroll = () => {
      if (scrollTween) scrollTween.kill();
      if (pinTrigger) pinTrigger.kill();

      const totalWidth = getScrollWidth();

      scrollTween = gsap.to(track, {
        x: -totalWidth,
        ease: 'none',
      });

      pinTrigger = ScrollTrigger.create({
        trigger: '#lb-h-scroll-outer',
        pin: '#lb-h-scroll-inner',
        start: 'top top',
        end: () => `+=${totalWidth}`,
        scrub: 1,
        animation: scrollTween,
        invalidateOnRefresh: true,
      });
    };

    initHorizontalScroll();

    // Reinit on resize
    window.addEventListener('resize', () => {
      ScrollTrigger.refresh();
    });
  }

  // ─── Filter button interactions ───────────────────────
  const filterBtns = document.querySelectorAll('.lb-filter-btn');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // ─── Drag to scroll (pointer events) ─────────────────
  if (track) {
    let isDragging = false;
    let startX = 0;
    let scrollStart = 0;

    track.addEventListener('pointerdown', (e) => {
      isDragging = true;
      startX = e.clientX;
      // Get current transform X
      const transform = gsap.getProperty(track, 'x') as number;
      scrollStart = transform;
      track.setPointerCapture(e.pointerId);
    });

    track.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      // Manual drag doesn't interact well with pinned ScrollTrigger
      // so just use mouse wheel to scroll the window when pinned
    });

    track.addEventListener('pointerup', () => {
      isDragging = false;
    });
  }
</script>
