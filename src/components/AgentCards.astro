---
const plugins = [
  {
    name: "Oracle: DexScreener",
    category: "Data Feed",
    desc: "Real-time token prices, liquidity, and volume across 80+ DEXs. Auto-discovers new pairs.",
    stats: { calls: "2.4M/day", latency: "< 50ms", uptime: "99.98%", chains: "12" },
    color: "#ffffff",
    examples: ["Price feeds", "Volume data", "Liquidity depth", "New pair alerts"],
  },
  {
    name: "Oracle: X Sentiment",
    category: "Sentiment",
    desc: "Scrapes X/Twitter for token mentions, whale alerts, and community sentiment. Feeds directly into agent reasoning.",
    stats: { calls: "840K/day", latency: "< 200ms", uptime: "99.7%", sources: "X, Reddit" },
    color: "#ffffff",
    examples: ["Whale tracking", "Sentiment score", "Trending tokens", "News alerts"],
  },
  {
    name: "Trade: Uniswap",
    category: "DEX Execution",
    desc: "Execute swaps on Uniswap V3 across Ethereum, Base, Arbitrum, and Polygon. Optimal routing built in.",
    stats: { calls: "180K/day", latency: "< 2s", uptime: "99.95%", chains: "4" },
    color: "#ffffff",
    examples: ["Token swaps", "Limit orders", "Multi-hop routing", "Slippage control"],
  },
  {
    name: "Trade: Polymarket",
    category: "Prediction Markets",
    desc: "Place bets on real-world events. AI analyzes probability vs. market odds and finds edges automatically.",
    stats: { calls: "45K/day", latency: "< 1s", uptime: "99.9%", markets: "500+" },
    color: "#ffffff",
    examples: ["Event betting", "Odds analysis", "Portfolio hedging", "Auto-rebalance"],
  },
  {
    name: "Agent: Claude",
    category: "AI Brain",
    desc: "Anthropic Claude as the trading brain. Autonomous multi-step reasoning, tool discovery, and risk management.",
    stats: { calls: "1.2M/day", latency: "< 3s", uptime: "99.9%", models: "3" },
    color: "#ffffff",
    examples: ["Strategy reasoning", "Risk assessment", "Tool selection", "Trade decisions"],
  },
  {
    name: "State: Redis",
    category: "Storage",
    desc: "High-performance state management. Trade history, portfolio tracking, and full audit trail at microsecond speed.",
    stats: { calls: "8.1M/day", latency: "< 1ms", uptime: "99.99%", storage: "Persistent" },
    color: "#ffffff",
    examples: ["Trade history", "Position tracking", "Audit trail", "Session state"],
  },
];

const PEEK = 44;
---
<section class="agents-section" id="agents">
  <div class="agents-section-header">
    <div class="section-label">Plugin Marketplace</div>
    <h2 class="section-title">Browse Plugins</h2>
  </div>

  <div class="agents-stack">
      {plugins.map((plugin, i) => (
        <div
          class="agent-card"
          data-index={i}
          style={`--agent-color: ${plugin.color}; --stack-index: ${i}; --peek-top: ${i * PEEK}px`}
        >
          <div class="agent-card-inner">
            <div class="agent-card-content">
              <div class="agent-top-row">
                <div class="agent-number mono">{String(i + 1).padStart(2, '0')}</div>
                <div class="agent-header-info">
                  <div>
                    <div class="agent-name">{plugin.name}</div>
                    <div class="badge" style={`background: rgba(255,255,255,0.05); color: var(--text-secondary); border: 1px solid var(--bg-border)`}>{plugin.category}</div>
                  </div>
                </div>
              </div>

              <p style="font-size:0.95rem;line-height:1.7;color:var(--text-secondary);margin:0.5rem 0 1rem">{plugin.desc}</p>

              <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-bottom:1rem">
                {plugin.examples.map((ex) => (
                  <span style="font-family:var(--font-mono);font-size:0.7rem;padding:0.2rem 0.6rem;background:rgba(255,255,255,0.03);border:1px solid var(--bg-border);color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em">{ex}</span>
                ))}
              </div>

              <div class="agent-stats-row">
                {Object.entries(plugin.stats).map(([key, val]) => (
                  <div class="stat-mini">
                    <div class="stat-mini-label">{key}</div>
                    <div class="stat-mini-value mono">{val}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
</section>

<style>
  .agents-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-base);
    overflow: hidden;
    box-sizing: border-box;
    padding-top: var(--nav-height, 80px);
  }

  .agents-section-header {
    flex-shrink: 0;
    padding: var(--space-lg) var(--space-lg) 0;
  }

  .agents-stack {
    position: relative;
    flex: 1;
    min-height: 0;
    margin: var(--space-lg);
  }

  .agent-card {
    position: absolute;
    top: calc(1rem + var(--peek-top, 0px));
    left: 1.5rem;
    right: 1.5rem;
    width: auto;
    height: calc(100% - 1rem - var(--peek-top, 0px));
    border-radius: 0;
    background: #111111;
    border: 1px solid #222222;
    border-bottom: none;
    will-change: transform;
  }

  .agent-card-inner {
    height: 100%;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    border-radius: 0;
  }

  .agent-card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.5rem 2rem;
    gap: 1rem;
  }

  /* Top row */
  .agent-top-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .agent-number {
    font-size: 1rem;
    color: rgba(255,255,255,0.3);
    font-weight: 600;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }

  .agent-header-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
  }

  .agent-avatar {
    width: 48px;
    height: 48px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .agent-initial {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--agent-color);
  }

  .agent-name {
    font-family: var(--font-pixel);
    font-weight: 300;
    font-size: 1.5rem;
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: 0.3rem;
  }

  .badge {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    display: inline-block;
  }

  .agent-pnl {
    text-align: right;
    flex-shrink: 0;
    margin-left: auto;
  }

  .pnl-value {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .pnl-pct {
    font-size: 0.85rem;
    opacity: 0.8;
  }

  /* Chart */
  .agent-chart {
    height: 80px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.04);
  }

  .sparkline {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Stats */
  .agent-stats-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .stat-mini {
    flex: 1;
    min-width: 80px;
    text-align: center;
    padding: 0.75rem 1rem;
    background: rgba(0,0,0,0.4);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.04);
  }

  .stat-mini-label {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.3rem;
  }

  .stat-mini-value {
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }

  @media (max-width: 768px) {
    .agent-card-content {
      padding: 1.5rem;
      gap: 1.25rem;
    }

    .agent-top-row {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .agent-name {
      font-size: 1.1rem;
    }

    .pnl-value {
      font-size: 1.1rem;
    }

    .agent-stats-row {
      gap: 0.5rem;
    }

    .stat-mini {
      min-width: 60px;
      padding: 0.5rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('.agents-section') as HTMLElement;
  const cards = gsap.utils.toArray<HTMLElement>('.agent-card');

  if (section && cards.length > 0) {
    cards.forEach((card, i) => {
      card.style.zIndex = String(i + 1);
      if (i > 0) {
        gsap.set(card, { yPercent: 100 });
      }
    });

    const tl = gsap.timeline();
    cards.forEach((card, i) => {
      if (i === 0) return;
      tl.to(card, { yPercent: 0, duration: 1, ease: 'power2.out' });
      tl.to({}, { duration: 0.15 });
    });

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${(cards.length - 1) * 100}vh`,
      pin: true,
      pinSpacing: true,
      scrub: 0.8,
      animation: tl,
    });
  }
</script>
