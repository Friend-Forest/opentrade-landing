---
const agents = [
  {
    name: "Alpha-7",
    strategy: "Momentum trading strategy with positive 7-day performance.",
    pnl7d: "+$12,847",
    pnlPct: "+23.4%",
    positive: true,
    color: "#00F0FF",
  },
  {
    name: "Mochi-9",
    strategy: "Sentiment trading strategy with positive 7-day performance.",
    pnl7d: "+$8,291",
    pnlPct: "+18.9%",
    positive: true,
    color: "#00FF88",
  },
  {
    name: "Zeta-3",
    strategy: "Arbitrage trading strategy with negative 7-day performance.",
    pnl7d: "-$1,204",
    pnlPct: "-2.8%",
    positive: false,
    color: "#FF394A",
  },
  {
    name: "Nexus-1",
    strategy: "Mean reversion trading strategy with positive 7-day performance.",
    pnl7d: "+$19,440",
    pnlPct: "+41.2%",
    positive: true,
    color: "#8B5CF6",
  },
  {
    name: "Byte-12",
    strategy: "On-chain intel trading strategy with positive 7-day performance.",
    pnl7d: "+$6,102",
    pnlPct: "+15.3%",
    positive: true,
    color: "#FFE600",
  },
  {
    name: "Oracle-X",
    strategy: "ML prediction trading strategy with positive 7-day performance.",
    pnl7d: "+$24,810",
    pnlPct: "+52.7%",
    positive: true,
    color: "#FF6B00",
  },
];
---

<section class="agents-section section">
  <div class="container">
    <div class="agents-header" data-reveal>
      <h2 class="agents-title">
        <span class="title-line">Top</span>
        <span class="title-line title-highlight">Trading Agents</span>
      </h2>
    </div>

    <div class="agents-items">
      {agents.map((agent, i) => (
        <div class="agent-card" data-reveal style={`--item-bg: #0a0a0a; --item-accent: ${agent.color}`}>
          <div class="agent-card-inner">
            <div class="agent-top">
              <div class="agent-avatar-block">
                <div class="agent-icon">
                  <svg viewBox="0 0 60 60" fill="none">
                    <polygon points="30,5 55,50 5,50" stroke={agent.color} stroke-width="2" fill="none" opacity="0.5"/>
                    <polygon points="30,15 45,45 15,45" fill={agent.color} opacity="0.2"/>
                  </svg>
                </div>
                <p class="agent-num">{String(i + 1).padStart(2, '0')}</p>
              </div>
              <div class="agent-info">
                <h3 class="agent-name">{agent.name}</h3>
                <p class="agent-desc">{agent.strategy}</p>
              </div>
            </div>
            <div class="agent-pnl">
              <div class={`pnl-value mono ${agent.positive ? 'positive' : 'negative'}`}>{agent.pnl7d}</div>
              <div class={`pnl-pct mono ${agent.positive ? 'positive' : 'negative'}`}>{agent.pnlPct}</div>
            </div>
            <div class="agent-symbol">
              <svg viewBox="0 0 100 100" fill="none">
                <polygon points="50,5 95,95 5,95" stroke={agent.color} stroke-width="1.5" fill="none"/>
                <polygon points="50,25 75,75 25,75" fill={agent.color} opacity="0.15"/>
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .agents-section {
    background: var(--color-neutral-950);
    padding-top: var(--padding-3xl);
    padding-bottom: var(--padding-3xl);
  }

  .agents-header {
    margin-bottom: var(--gap-2xl);
  }

  .agents-title {
    font-size: var(--text-8xl);
    line-height: var(--leading-normal);
    font-weight: 400;
    text-transform: uppercase;
  }

  .title-line {
    display: block;
    color: rgba(255,255,255,0.3);
  }

  .title-highlight {
    color: var(--color-white);
  }

  .agents-items {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .agent-card {
    background: var(--item-bg, #0a0a0a);
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
    clip-path: polygon(
      0% 0%,
      100% 0%,
      100% calc(100% - 30px),
      calc(100% - 30px) 100%,
      0% 100%
    );
    transition: background 0.3s ease;
  }

  .agent-card:hover {
    border-color: rgba(255,255,255,0.1);
  }

  .agent-card-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--padding-xl) var(--padding-2xl);
    position: relative;
    z-index: 2;
    gap: var(--gap-xl);
  }

  .agent-top {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-xl);
    flex: 1;
  }

  .agent-avatar-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    width: clamp(3rem, 5vw, 5rem);
  }

  .agent-icon {
    width: clamp(2.5rem, 4vw, 4rem);
    height: clamp(2.5rem, 4vw, 4rem);
  }

  .agent-icon svg {
    width: 100%;
    height: 100%;
  }

  .agent-num {
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .agent-info {
    flex: 1;
  }

  .agent-name {
    font-size: var(--text-5xl);
    font-weight: 400;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 1rem;
    line-height: var(--leading-normal);
  }

  .agent-desc {
    font-size: var(--text-base);
    color: var(--color-neutral-400);
    line-height: 1.6;
    max-width: 60ch;
  }

  .agent-pnl {
    text-align: right;
    flex-shrink: 0;
  }

  .pnl-value {
    font-size: var(--text-4xl);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .pnl-value.positive { color: #00FF88; }
  .pnl-value.negative { color: #FF394A; }

  .pnl-pct {
    font-size: var(--text-base);
    opacity: 0.8;
  }

  .pnl-pct.positive { color: #00FF88; }
  .pnl-pct.negative { color: #FF394A; }

  .agent-symbol {
    width: clamp(4rem, 7vw, 7rem);
    height: clamp(4rem, 7vw, 7rem);
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }

  .agent-symbol svg {
    width: 100%;
    height: 100%;
  }

  .agent-card:hover .agent-symbol {
    opacity: 0.7;
  }

  /* Item accent glow */
  .agent-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    background: radial-gradient(ellipse at 80% 50%, var(--item-accent, transparent) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .agent-card-inner {
      padding: var(--padding-xl);
    }

    .agent-top {
      flex-direction: column;
      gap: 1rem;
    }

    .agent-avatar-block {
      flex-direction: row;
      width: auto;
    }

    .agent-symbol {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .agent-card-inner {
      flex-direction: column;
      padding: 1.5rem;
    }

    .agent-title {
      font-size: var(--text-4xl);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  
  // EXACT Avax Why pattern: simple IntersectionObserver stagger
  const cards = document.querySelectorAll('.agent-card');
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const idx = Array.from(cards).indexOf(el);
        gsap.from(el, {
          x: -50,
          opacity: 0,
          duration: 0.8,
          delay: idx * 0.1,
          ease: 'power3.out'
        });
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.2 });
  
  cards.forEach(card => observer.observe(card));
</script>
