---
const agents = [
  {
    num: "01",
    title: "ALPHA-7",
    desc: "Momentum trading strategy with positive 7-day performance of +23.4%.",
    pnl: "+$12,847",
    pct: "+23.4%",
    positive: true,
    color: "#00F0FF",
    bg: "#021a1a"
  },
  {
    num: "02",
    title: "MOCHI-9",
    desc: "Sentiment trading strategy with positive 7-day performance of +18.9%.",
    pnl: "+$8,291",
    pct: "+18.9%",
    positive: true,
    color: "#00FF88",
    bg: "#021a0a"
  },
  {
    num: "03",
    title: "ZETA-3",
    desc: "Arbitrage trading strategy with negative 7-day performance of -2.8%.",
    pnl: "-$1,204",
    pct: "-2.8%",
    positive: false,
    color: "#FF394A",
    bg: "#1a0202"
  },
  {
    num: "04",
    title: "NEXUS-1",
    desc: "Mean reversion trading strategy with positive 7-day performance of +41.2%.",
    pnl: "+$19,440",
    pct: "+41.2%",
    positive: true,
    color: "#8B5CF6",
    bg: "#1a0a2a"
  },
  {
    num: "05",
    title: "BYTE-12",
    desc: "On-chain intel trading strategy with positive 7-day performance of +15.3%.",
    pnl: "+$6,102",
    pct: "+15.3%",
    positive: true,
    color: "#FFE600",
    bg: "#1a1a02"
  },
  {
    num: "06",
    title: "ORACLE-X",
    desc: "ML prediction trading strategy with positive 7-day performance of +52.7%.",
    pnl: "+$24,810",
    pct: "+52.7%",
    positive: true,
    color: "#FF6B00",
    bg: "#1a0f02"
  },
];
---

<section class="agents-section">
  <div class="agents-header">
    <h2 class="agents-title">
      <span class="title-line">Top</span>
      <span class="title-line title-highlight">Trading Agents</span>
    </h2>
  </div>

  <div class="agents-items">
    {agents.map((agent) => (
      <div class="agent-card" style={`--item-bg: ${agent.bg}; --item-accent: ${agent.color}`}>
        <div class="agent-card-inner">
          <div class="agent-number">{agent.num}</div>
          <div class="agent-content">
            <h3 class="agent-title">{agent.title}</h3>
            <p class="agent-desc">{agent.desc}</p>
          </div>
          <div class="agent-pnl">
            <div class={`pnl-value ${agent.positive ? 'positive' : 'negative'}`}>{agent.pnl}</div>
            <div class={`pnl-pct ${agent.positive ? 'positive' : 'negative'}`}>{agent.pct}</div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .agents-section {
    background: #0a0a0a;
    padding: 6rem 0;
  }

  .agents-header {
    padding: 0 4rem;
    margin-bottom: 3rem;
  }

  .agents-title {
    font-size: 4rem;
    line-height: 1.1;
    font-weight: 400;
    text-transform: uppercase;
  }

  .title-line {
    display: block;
    color: rgba(255,255,255,0.3);
  }

  .title-highlight {
    color: #fff;
  }

  .agents-items {
    display: flex;
    flex-direction: column;
    gap: 2px !important;
    padding: 0 4rem;
    margin: 0;
  }

  .agent-card {
    background: var(--item-bg, #0a0a0a);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 16px;
    overflow: hidden;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .agent-card:hover {
    border-color: rgba(255,255,255,0.1);
  }

  .agent-card-inner {
    display: flex;
    align-items: center;
    padding: 2.5rem 3rem;
    gap: 2rem;
  }

  .agent-number {
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    min-width: 2rem;
  }

  .agent-content {
    flex: 1;
  }

  .agent-title {
    font-size: 2rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .agent-desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    max-width: 700px;
  }

  .agent-pnl {
    text-align: right;
    flex-shrink: 0;
  }

  .pnl-value {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .pnl-value.positive { color: #00FF88; }
  .pnl-value.negative { color: #FF394A; }

  .pnl-pct {
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .pnl-pct.positive { color: #00FF88; }
  .pnl-pct.negative { color: #FF394A; }

  @media (max-width: 1024px) {
    .agents-header,
    .agents-items {
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .agent-card-inner {
      padding: 2rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .agent-pnl {
      text-align: left;
    }
  }

  @media (max-width: 768px) {
    .agents-title {
      font-size: 2.5rem;
    }

    .agent-title {
      font-size: 1.5rem;
    }

    .agent-card-inner {
      padding: 1.5rem;
    }
  }
</style>

<script>
  // Wait for GSAP CDN to load
  const waitForGsap = setInterval(() => {
    if (typeof gsap !== 'undefined') {
      clearInterval(waitForGsap);
      initAnimation();
    }
  }, 50);
  
  function initAnimation() {
    const items = document.querySelectorAll('.agent-card');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const idx = Array.from(items).indexOf(el);
          gsap.from(el, {
            x: -50,
            opacity: 0,
            duration: 0.8,
            delay: idx * 0.1,
            ease: 'power3.out'
          });
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.2 });
    
    items.forEach(item => observer.observe(item));
  }
</script>
