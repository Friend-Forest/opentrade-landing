---
<section class="agents-section" id="agents">
  <div class="container">
    <div class="section-label">Live Performance</div>
    <div class="agents-header">
      <h2 class="section-title">Top Trading Agents</h2>
      <a href="#deploy" class="btn btn-secondary">View All Agents</a>
    </div>

    <div class="agents-grid">
      {agents.map((agent, i) => (
        <div class="agent-card card" data-index={i} style={`--agent-color: ${agent.color}`}>
          <!-- Header -->
          <div class="agent-header">
            <div class="agent-avatar" style={`background: linear-gradient(135deg, ${agent.color}33, ${agent.color}11); border: 1px solid ${agent.color}55`}>
              <span class="agent-initial mono">{agent.name[0]}</span>
            </div>
            <div class="agent-info">
              <div class="agent-name">{agent.name}</div>
              <div class="badge" style={`background: ${agent.color}18; color: ${agent.color}; border: 1px solid ${agent.color}40; font-size: 0.65rem`}>{agent.strategy}</div>
            </div>
            <div class="agent-pnl">
              <div class={`pnl-value mono ${agent.positive ? 'positive' : 'negative'}`}>{agent.pnl7d}</div>
              <div class={`pnl-pct mono ${agent.positive ? 'positive' : 'negative'}`}>{agent.pnlPct}</div>
            </div>
          </div>

          <!-- Sparkline -->
          <div class="agent-chart">
            <svg class="sparkline" viewBox={`0 0 ${(agent.sparkline.length - 1) * 20} 50`} preserveAspectRatio="none">
              <defs>
                <linearGradient id={`grad-${i}`} x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color={agent.color} stop-opacity="0.4"/>
                  <stop offset="100%" stop-color={agent.color} stop-opacity="0"/>
                </linearGradient>
              </defs>
              <!-- Area fill -->
              <path
                d={`M0,${50 - (agent.sparkline[0] / 140) * 50} ${agent.sparkline.map((v, idx) => `L${idx * 20},${50 - (v / 140) * 50}`).join(' ')} L${(agent.sparkline.length - 1) * 20},50 L0,50 Z`}
                fill={`url(#grad-${i})`}
              />
              <!-- Line -->
              <polyline
                points={agent.sparkline.map((v, idx) => `${idx * 20},${50 - (v / 140) * 50}`).join(' ')}
                fill="none"
                stroke={agent.color}
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <!-- Last point dot -->
              <circle
                cx={(agent.sparkline.length - 1) * 20}
                cy={50 - (agent.sparkline[agent.sparkline.length - 1] / 140) * 50}
                r="3"
                fill={agent.color}
              />
            </svg>
          </div>

          <!-- Stats row -->
          <div class="agent-stats">
            <div class="stat-mini">
              <div class="stat-mini-label">TVL</div>
              <div class="stat-mini-value mono">{agent.tvl}</div>
            </div>
            <div class="stat-mini">
              <div class="stat-mini-label">Win Rate</div>
              <div class="stat-mini-value mono" style={`color:${agent.color}`}>{agent.winRate}</div>
            </div>
            <div class="stat-mini">
              <div class="stat-mini-label">Trades</div>
              <div class="stat-mini-value mono">{agent.trades}</div>
            </div>
          </div>

          <!-- Token info -->
          <div class="agent-token">
            <span class="token-badge mono">{agent.token}</span>
            <span class="token-price mono" style={`color:${agent.color}`}>{agent.tokenPrice}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .agents-section {
    padding: var(--space-3xl) 0;
    background: linear-gradient(180deg, var(--bg-base) 0%, var(--bg-surface) 100%);
  }

  .agents-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .agents-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .agent-card {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
    transform: translateY(20px) scale(0.98);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
  }

  .agent-card.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .agent-card:hover {
    border-color: var(--agent-color);
    box-shadow: 0 0 20px color-mix(in srgb, var(--agent-color) 25%, transparent),
                0 0 60px color-mix(in srgb, var(--agent-color) 10%, transparent);
    transform: translateY(-3px) scale(1.01);
  }

  /* Header */
  .agent-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .agent-avatar {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .agent-initial {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--agent-color);
  }

  .agent-info { flex: 1; }

  .agent-name {
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 0.3rem;
  }

  .agent-pnl {
    text-align: right;
  }

  .pnl-value {
    font-size: 1rem;
    font-weight: 700;
  }

  .pnl-pct {
    font-size: 0.75rem;
    opacity: 0.8;
  }

  /* Sparkline */
  .agent-chart {
    border-radius: 6px;
    overflow: hidden;
    background: rgba(0,0,0,0.2);
    height: 52px;
  }

  .sparkline {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Stats */
  .agent-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .stat-mini {
    text-align: center;
    padding: 0.5rem 0.25rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid var(--bg-border);
  }

  .stat-mini-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }

  .stat-mini-value {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  /* Token */
  .agent-token {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid var(--bg-border);
  }

  .token-badge {
    font-size: 0.7rem;
    color: var(--text-secondary);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .token-price {
    font-size: 0.8rem;
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .agents-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .agents-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const cards = document.querySelectorAll('.agent-card');
        cards.forEach((card, i) => {
          setTimeout(() => card.classList.add('visible'), i * 80);
        });
        observer.disconnect();
      }
    });
  }, { threshold: 0.1 });

  const grid = document.querySelector('.agents-grid');
  if (grid) observer.observe(grid);
</script>
