---
---
<section class="hero" id="hero">
  <!-- Animated background layers (parallax) -->
  <div class="hero-bg">
    <div class="hero-grid grid-bg" id="hero-grid-parallax"></div>
    <div class="hero-gradient"></div>
    <!-- Particle layer (slower parallax) -->
    <canvas id="particle-canvas" class="hero-canvas" data-parallax-speed="0.3"></canvas>
    <!-- Floating orbs (medium parallax) -->
    <div class="hero-orb orb-1" data-parallax-speed="0.15"></div>
    <div class="hero-orb orb-2" data-parallax-speed="0.25"></div>
    <div class="hero-orb orb-3" data-parallax-speed="0.1"></div>
  </div>

  <!-- Scan line effect -->
  <div class="scan-line"></div>

  <!-- Foreground content (faster parallax) -->
  <div class="hero-content container" id="hero-foreground">
    <!-- Left: Terminal -->
    <div class="hero-terminal-wrapper">
      <!-- Sliding reveal wrapper -->
      <div class="reveal-mask">
        <div class="terminal hero-terminal animate-glow-pulse reveal-text" id="hero-terminal-reveal">
          <div class="terminal-header">
            <div class="terminal-dot" style="background:#FF5F56"></div>
            <div class="terminal-dot" style="background:#FFBD2E"></div>
            <div class="terminal-dot" style="background:#27C93F"></div>
            <span style="margin-left:0.5rem;font-family:var(--font-mono);font-size:0.75rem;color:var(--text-secondary)">opentrade-agent v2.4.1</span>
          </div>
          <div class="terminal-body" id="terminal-output">
            <div class="terminal-line">
              <span class="terminal-prompt"></span>
              <span id="typing-text"></span><span class="animate-blink" style="color:#ffffff">█</span>
            </div>
            <div id="terminal-history"></div>
          </div>
        </div>
      </div>

      <!-- Floating stats -->
      <div class="hero-float-card float-1" id="float-card-1">
        <div class="float-label">24h PnL</div>
        <div class="float-value positive">+$47,291</div>
      </div>
      <div class="hero-float-card float-2" id="float-card-2">
        <div class="float-label">Active Agents</div>
        <div class="float-value" style="color:#888888">1,247</div>
      </div>
    </div>

    <!-- Right: Copy -->
    <div class="hero-copy">
      <div class="reveal-mask">
        <div class="section-label reveal-text" id="hero-label-reveal">AI-Powered Trading Engine</div>
      </div>

      <h1 class="hero-heading">
        <div class="reveal-mask"><div class="reveal-text" id="hero-h1-1"><span class="text-gradient-cyan">One Engine.</span></div></div>
        <div class="reveal-mask"><div class="reveal-text" id="hero-h1-2">Every Market.</div></div>
        <div class="reveal-mask"><div class="reveal-text" id="hero-h1-3"><span class="glow-green">24/7.</span></div></div>
      </h1>

      <div class="reveal-mask" style="margin-top:1rem">
        <p class="hero-desc reveal-text" id="hero-desc-reveal">
          Deploy autonomous AI agents that trade crypto, stocks, prediction markets, and more.
          Every trade generates fees that buy back the OpenTrade token. Every profit compounds.
          <span style="color:#ffffff;font-family:var(--font-pixel);font-size:1.1rem;font-weight:300">The universal AI trader.</span>
        </p>
      </div>

      <div class="hero-actions" id="hero-actions">
        <a href="#deploy" class="btn btn-primary" style="font-size:1rem;padding:0.875rem 2rem">
          Create Agent
          <span class="pixel-icon" style="font-size:1rem">→</span>
        </a>
        <a href="#how-it-works" class="btn btn-secondary" style="font-size:1rem;padding:0.875rem 2rem">
          How It Works
        </a>
      </div>

      <div class="hero-badges" id="hero-badges">
        <span class="badge badge-cyan">Any Market</span>
        <span class="badge badge-green">Non-Custodial</span>
        <span class="badge badge-purple">Plugin Ecosystem</span>
      </div>
    </div>
  </div>

  <!-- Ticker tape -->
  <div class="ticker-wrapper">
    <div class="ticker-inner">
      <div class="ticker-track" id="ticker">
        <span class="ticker-item positive">BTC +3.2% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">ETH -1.1% ▼</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">SOL +8.7% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">BASE +5.4% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">DOGE -2.3% ▼</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">AVAX +4.1% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">LINK +6.8% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">ARB -0.9% ▼</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">OP +3.5% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">Agent-Alpha +124% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">Agent-Mochi +89% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">Agent-Zeta -4.2% ▼</span>
        <span class="ticker-sep">·</span>
        <!-- Duplicate for seamless loop -->
        <span class="ticker-item positive">BTC +3.2% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">ETH -1.1% ▼</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">SOL +8.7% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">BASE +5.4% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">DOGE -2.3% ▼</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">AVAX +4.1% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">LINK +6.8% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">ARB -0.9% ▼</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">OP +3.5% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">Agent-Alpha +124% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item positive">Agent-Mochi +89% ▲</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-item negative">Agent-Zeta -4.2% ▼</span>
        <span class="ticker-sep">·</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    opacity: 0.6;
    will-change: transform;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: transparent;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    opacity: 0.4;
    will-change: transform;
  }

  /* Floating orb parallax elements */
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
    pointer-events: none;
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    background: transparent;
    top: -100px;
    right: -100px;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: transparent;
    bottom: 100px;
    left: -50px;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: transparent;
    top: 40%;
    left: 30%;
  }

  .scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.08);
    animation: scan-line 8s linear infinite;
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-top: 4rem;
    padding-bottom: 2rem;
    will-change: transform;
  }

  /* Terminal */
  .hero-terminal-wrapper {
    position: relative;
  }

  .hero-terminal {
    width: 100%;
  }

  .hero-terminal .terminal-body {
    font-size: 0.82rem;
    min-height: 300px;
  }

  .terminal-line {
    line-height: 1.8;
  }

  #terminal-history .hist-prompt::before {
    content: '$ ';
    color: #00FF00;
  }

  #terminal-history .hist-output {
    color: #8090b0;
    margin-left: 1rem;
    display: block;
  }

  #terminal-history .hist-success {
    color: #00FF00;
    margin-left: 1rem;
    display: block;
  }

  #terminal-history .hist-info {
    color: #00F0FF;
    margin-left: 1rem;
    display: block;
  }

  /* Float cards */
  .hero-float-card {
    position: absolute;
    background: rgba(17, 17, 17, 0.95);
    border: 1px solid #333333;
    border-radius: 0;
    padding: 0.75rem 1rem;
    animation: float 3s ease-in-out infinite;
    opacity: 0;
    will-change: transform, opacity;
  }

  .float-1 {
    bottom: -20px;
    right: -20px;
    animation-delay: 0s;
  }

  .float-2 {
    top: 20px;
    right: -30px;
    animation-delay: 1.5s;
  }

  .float-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: #8090b0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.25rem;
  }

  .float-value {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
  }

  /* Hero copy */
  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-heading {
    font-family: var(--font-pixel);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .hero-desc {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #8090b0;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    opacity: 0;
  }

  /* Ticker */
  .ticker-wrapper {
    position: relative;
    z-index: 3;
    border-top: 1px solid #222222;
    background: rgba(0, 0, 0, 0.8);
    overflow: hidden;
    height: 44px;
    display: flex;
    align-items: center;
  }

  .ticker-inner {
    width: 100%;
    overflow: hidden;
  }

  .ticker-track {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    white-space: nowrap;
    animation: ticker 40s linear infinite;
  }

  .ticker-item {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .ticker-sep {
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-top: 2rem;
    }

    .hero-terminal-wrapper {
      order: 2;
    }

    .hero-copy { order: 1; }

    .float-1, .float-2 { display: none; }
  }

  @media (max-width: 600px) {
    .hero-heading { font-size: 2.2rem; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Connect GSAP ScrollTrigger with Lenis
  window.addEventListener('lenis-ready', (e: Event) => {
    const lenis = (e as CustomEvent).detail;
    if (lenis) {
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time: number) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);
    }
  });

  // ─── Hero entrance animations ───────────────────────────
  const tl = gsap.timeline({ delay: 0.2 });

  // Reveal text elements
  tl.to('#hero-label-reveal', { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' })
    .to('#hero-h1-1', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, '-=0.4')
    .to('#hero-h1-2', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, '-=0.5')
    .to('#hero-h1-3', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, '-=0.5')
    .to('#hero-desc-reveal', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' }, '-=0.4')
    .to('#hero-terminal-reveal', { y: 0, opacity: 1, duration: 1, ease: 'power3.out' }, '-=0.6')
    .to('.hero-actions', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3')
    .to('.hero-badges', { opacity: 1, duration: 0.6, ease: 'power2.out' }, '-=0.4')
    .to('#float-card-1', { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.2')
    .to('#float-card-2', { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.3');

  // Set initial states
  gsap.set(['#hero-label-reveal', '#hero-h1-1', '#hero-h1-2', '#hero-h1-3', '#hero-desc-reveal', '#hero-terminal-reveal'], {
    y: 60,
    opacity: 0
  });

  // ─── Parallax layers on scroll ───────────────────────────
  // Grid parallax (slowest - background)
  gsap.to('#hero-grid-parallax', {
    yPercent: -20,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 1,
    }
  });

  // Canvas particles (medium speed)
  gsap.to('#particle-canvas', {
    yPercent: -35,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 1.5,
    }
  });

  // Orbs (different speeds for depth effect)
  gsap.to('.orb-1', {
    yPercent: -15,
    xPercent: 5,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 2,
    }
  });

  gsap.to('.orb-2', {
    yPercent: -25,
    xPercent: -3,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 1.2,
    }
  });

  gsap.to('.orb-3', {
    yPercent: -30,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 0.8,
    }
  });

  // Hero foreground content (faster = feels closest)
  gsap.to('#hero-foreground', {
    yPercent: -8,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 0.5,
    }
  });

  // ─── Typing terminal animation ─────────────────────────
  const sequences = [
    {
      cmd: 'opentrade agent create --strategy momentum --risk 0.02',
      outputs: [
        { text: 'Generating wallet...', type: 'output' },
        { text: '✓ Wallet created: 0x8f2a...c4d1', type: 'success' },
        { text: '✓ Agent "Alpha-7" initialized', type: 'success' },
        { text: '✓ Monitoring crypto, stocks, prediction markets', type: 'success' },
      ]
    },
    {
      cmd: 'opentrade stats --agent Alpha-7 --period 7d',
      outputs: [
        { text: '━━━━━━━━━━ Performance Report ━━━━━━━━━━', type: 'info' },
        { text: '7d PnL: +$12,847 (+23.4%)', type: 'success' },
        { text: 'Trades: 342 | Win Rate: 67.8%', type: 'output' },
        { text: 'Fees generated: $1,842 → 80% to $OT buyback', type: 'info' },
      ]
    },
    {
      cmd: 'opentrade launch-token --agent Alpha-7',
      outputs: [
        { text: 'Deploying agent token ALPHA7...', type: 'output' },
        { text: '✓ Token live. Trading fees: 80% compounds, 20% → $OT', type: 'success' },
        { text: '✓ Profit buyback: 15% of gains → ALPHA7 buyback', type: 'success' },
        { text: '✓ Flywheel active. All systems green.', type: 'success' },
      ]
    }
  ];

  let seqIndex = 0;
  const typingEl = document.getElementById('typing-text');
  const historyEl = document.getElementById('terminal-history');
  const MAX_HISTORY = 12;

  function sleep(ms: number) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function addToHistory(text: string, type: string) {
    const line = document.createElement('div');
    if (type === 'cmd') {
      line.className = 'hist-prompt';
      line.style.color = 'var(--text-primary)';
    } else if (type === 'success') {
      line.className = 'hist-success';
    } else if (type === 'info') {
      line.className = 'hist-info';
    } else {
      line.className = 'hist-output';
    }
    line.textContent = text;
    historyEl?.appendChild(line);

    const lines = historyEl?.querySelectorAll('div') || [];
    if (lines.length > MAX_HISTORY) {
      lines[0]?.remove();
    }
    historyEl?.scrollTo(0, historyEl.scrollHeight);
  }

  async function runSequence() {
    const seq = sequences[seqIndex % sequences.length];
    seqIndex++;

    const cmd = seq.cmd;
    if (typingEl) typingEl.textContent = '';

    for (const char of cmd) {
      if (typingEl) typingEl.textContent += char;
      await sleep(40 + Math.random() * 30);
    }

    await sleep(400);
    addToHistory(cmd, 'cmd');
    if (typingEl) typingEl.textContent = '';

    for (const out of seq.outputs) {
      await sleep(300 + Math.random() * 200);
      addToHistory(out.text, out.type);
    }

    await sleep(2500);
    runSequence();
  }

  setTimeout(runSequence, 1200);

  // ─── Particle canvas ──────────────────────────────────
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');

    const resize = () => {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    };
    resize();
    window.addEventListener('resize', resize);

    interface Particle {
      x: number; y: number;
      vx: number; vy: number;
      size: number;
      alpha: number;
      color: string;
    }

    const particles: Particle[] = [];
    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
    const COLORS = isLight ? ['#000000', '#888888', '#aaaaaa'] : ['#ffffff', '#888888', '#555555'];

    for (let i = 0; i < 70; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        size: Math.random() * 2 + 0.5,
        alpha: Math.random() * 0.5 + 0.1,
        color: COLORS[Math.floor(Math.random() * COLORS.length)]
      });
    }

    function animateParticles() {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;

        if (p.x < 0) p.x = canvas.width;
        if (p.x > canvas.width) p.x = 0;
        if (p.y < 0) p.y = canvas.height;
        if (p.y > canvas.height) p.y = 0;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = p.alpha;
        ctx.fill();
        ctx.globalAlpha = 1;
      });

      particles.forEach((a, i) => {
        particles.slice(i + 1).forEach(b => {
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 100) {
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = isLight ? '#cccccc' : '#444444';
            ctx.globalAlpha = (1 - dist / 100) * 0.12;
            ctx.lineWidth = 0.5;
            ctx.stroke();
            ctx.globalAlpha = 1;
          }
        });
      });

      requestAnimationFrame(animateParticles);
    }

    animateParticles();
  }
</script>
