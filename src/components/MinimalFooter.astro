---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <!-- Logo + tagline -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span class="footer-brand-name" style="font-family:var(--font-pixel);font-weight:300;color:#ffffff">OpenTrade</span>
      </a>
      <p class="footer-tagline mono">One engine. Every market. 24/7.</p>
    </div>

    <!-- Links -->
    <div class="footer-links">
      <div class="footer-col">
        <div class="footer-col-title">Platform</div>
        <a href="#how-it-works">How It Works</a>
        <a href="#agents">Agents</a>
        <a href="#tokenomics">Tokenomics</a>
        <a href="#leaderboard">Leaderboard</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Resources</div>
        <a href="https://docs.opentrade.io" target="_blank">Documentation</a>
        <a href="https://github.com/0xmemo-claw" target="_blank">GitHub</a>
        <a href="https://app.opentrade.io" target="_blank">Launch App</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Community</div>
        <a href="https://x.com/0xxmemo" target="_blank">Twitter / X</a>
        <a href="https://discord.gg/opentrade" target="_blank">Discord</a>
        <a href="https://t.me/opentrade" target="_blank">Telegram</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="mono" style="font-size:0.75rem;color:var(--text-muted)">
        © {year} OpenTrade. Built on Base. All rights reserved.
      </p>
      <div class="footer-socials">
        <a href="https://x.com/0xxmemo" target="_blank" class="social-link" aria-label="Twitter">
          <span class="pixel-icon" style="font-size:1rem">X</span>
        </a>
        <a href="https://discord.gg/opentrade" target="_blank" class="social-link" aria-label="Discord">
          <span class="pixel-icon" style="font-size:0.8rem">DC</span>
        </a>
        <a href="https://github.com/0xmemo-claw" target="_blank" class="social-link" aria-label="GitHub">
          <span class="pixel-icon" style="font-size:0.8rem">GH</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-surface);
    border-top: 1px solid var(--bg-border);
    margin-top: 0;
    position: relative;
    z-index: 10;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-brand-name {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1rem;
  }

  .footer-tagline {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 220px;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col-title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--cyan);
    margin-bottom: 0.25rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--text-primary); }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--bg-border);
    background: var(--bg-base);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--bg-card);
    border: 1px solid var(--bg-border);
    color: var(--text-secondary);
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .social-link:hover {
    color: var(--cyan);
    border-color: var(--cyan);
    background: rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
