---
---
<section class="how-section" id="how-it-works">
  <div class="how-header">
    <div class="reveal-mask">
      <div class="section-label reveal-text" id="how-label">Process</div>
    </div>
    <div class="reveal-mask">
      <h2 class="section-title reveal-text" id="how-title">How OpenTrade Works</h2>
    </div>
  </div>

  <div class="how-cards-area">
    <!-- Horizontal cards track -->
    <div class="how-cards-viewport">
      <div class="how-cards-track" id="how-cards-track">

        <!-- Step 1 -->
        <div class="how-card how-card-1">
          <div class="how-card-inner">
            <div class="step-visual">
              <div class="step-icon step-icon-1">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <circle cx="24" cy="24" r="20" stroke="#00F0FF" stroke-width="1.5" opacity="0.3"/>
                  <circle cx="24" cy="24" r="12" stroke="#00F0FF" stroke-width="1.5"/>
                  <path d="M24 16v8l5 5" stroke="#00F0FF" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="24" cy="24" r="2" fill="#00F0FF"/>
                </svg>
              </div>
            </div>
            <div class="step-content">
              <div class="step-number mono" style="color:var(--cyan)">01</div>
              <h3 class="step-title">Configure Your Agent</h3>
              <p class="step-desc">
                Define your trading strategy — momentum, mean reversion, sentiment, or arbitrage.
                Set risk parameters, capital allocation, and pair preferences.
                Your agent learns and adapts autonomously.
              </p>
              <div class="step-code terminal">
                <div class="terminal-header" style="padding:0.35rem 0.75rem">
                  <div class="terminal-dot" style="background:#FF5F56"></div>
                  <div class="terminal-dot" style="background:#FFBD2E"></div>
                  <div class="terminal-dot" style="background:#27C93F"></div>
                </div>
                <div class="terminal-body" style="padding:0.75rem 1rem;font-size:0.75rem">
                  <div class="terminal-prompt" style="color:#e0e8ff">agent create \</div>
                  <div style="color:#8090b0;margin-left:1rem">--strategy momentum \</div>
                  <div style="color:#8090b0;margin-left:1rem">--pairs ETH,SOL,BASE \</div>
                  <div style="color:#8090b0;margin-left:1rem">--max-risk 0.02</div>
                </div>
              </div>
            </div>
            <div class="card-scroll-hint">Scroll to continue →</div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="how-card how-card-2">
          <div class="how-card-inner">
            <div class="step-visual">
              <div class="step-icon step-icon-2">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <rect x="8" y="28" width="6" height="14" rx="1" fill="#00FF88" opacity="0.8"/>
                  <rect x="18" y="18" width="6" height="24" rx="1" fill="#00FF88"/>
                  <rect x="28" y="12" width="6" height="30" rx="1" fill="#00FF88" opacity="0.9"/>
                  <rect x="38" y="22" width="6" height="20" rx="1" fill="#00FF88" opacity="0.6"/>
                  <path d="M8 32L18 22L28 16L38 26" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="8" cy="32" r="2" fill="#00F0FF"/>
                  <circle cx="18" cy="22" r="2" fill="#00F0FF"/>
                  <circle cx="28" cy="16" r="2" fill="#00F0FF"/>
                  <circle cx="38" cy="26" r="2" fill="#00F0FF"/>
                </svg>
              </div>
            </div>
            <div class="step-content">
              <div class="step-number mono" style="color:var(--green)">02</div>
              <h3 class="step-title">Agent Trades 24/7</h3>
              <p class="step-desc">
                Once deployed, your agent executes trades autonomously — analyzing on-chain data,
                news sentiment, and price action. No emotions, no fatigue.
                Pure algorithmic precision around the clock.
              </p>
              <div class="step-metrics">
                <div class="metric-row">
                  <span class="metric-label">Execution Speed</span>
                  <span class="metric-value glow-green">&lt;50ms</span>
                </div>
                <div class="metric-row">
                  <span class="metric-label">Uptime</span>
                  <span class="metric-value glow-cyan">99.97%</span>
                </div>
                <div class="metric-row">
                  <span class="metric-label">Avg Win Rate</span>
                  <span class="metric-value" style="color:var(--cyan)">67.8%</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="how-card how-card-3">
          <div class="how-card-inner">
            <div class="step-visual">
              <div class="step-icon step-icon-3">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <path d="M24 8C15.2 8 8 15.2 8 24C8 32.8 15.2 40 24 40C32.8 40 40 32.8 40 24C40 15.2 32.8 8 24 8Z" stroke="#8B5CF6" stroke-width="1.5"/>
                  <path d="M24 14v6M24 28v6M14 24h6M28 24h6" stroke="#8B5CF6" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="24" cy="24" r="4" fill="#8B5CF6" opacity="0.6"/>
                  <path d="M18 18l-3-3M30 18l3-3M30 30l3 3M18 30l-3 3" stroke="#8B5CF6" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
                </svg>
              </div>
            </div>
            <div class="step-content">
              <div class="step-number mono" style="color:var(--purple)">03</div>
              <h3 class="step-title">Buyback Flywheel</h3>
              <p class="step-desc">
                Your agent's token benefits from automatic buybacks — trading fees trigger
                fee buybacks, profits trigger profit buybacks. A self-sustaining value loop
                that compounds as your agent performs.
              </p>
              <div class="flywheel">
                <div class="fw-step">
                  <div class="fw-step-icon fw-step-icon--fees">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                  </div>
                  <div class="fw-step-text">
                    <span class="fw-step-label">Trading Fees</span>
                    <span class="fw-step-sub">Collected on every trade</span>
                  </div>
                </div>
                <div class="fw-connector">
                  <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28m0 0l-6-5m6 5l-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="fw-step">
                  <div class="fw-step-icon fw-step-icon--buyback">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                  </div>
                  <div class="fw-step-text">
                    <span class="fw-step-label">Auto Buyback</span>
                    <span class="fw-step-sub">Token purchased from market</span>
                  </div>
                </div>
                <div class="fw-connector">
                  <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28m0 0l-6-5m6 5l-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="fw-step">
                  <div class="fw-step-icon fw-step-icon--value">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                  </div>
                  <div class="fw-step-text">
                    <span class="fw-step-label">Value Accrual</span>
                    <span class="fw-step-sub">Token price compounds</span>
                  </div>
                </div>
                <div class="fw-loop">
                  <svg width="100%" height="24" viewBox="0 0 400 24" preserveAspectRatio="none" fill="none">
                    <path d="M400 4C300 4 300 20 200 20S100 4 0 4" stroke="rgba(139,92,246,0.3)" stroke-width="1.5" stroke-dasharray="4 4"/>
                  </svg>
                  <span class="fw-loop-label mono">Cycle repeats</span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Step dots navigation -->
    <div class="how-dots" id="how-dots">
      <button class="how-dot active" data-step="0"></button>
      <button class="how-dot" data-step="1"></button>
      <button class="how-dot" data-step="2"></button>
    </div>
  </div>
</section>

<style>
  .how-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-base);
    overflow: hidden;
    box-sizing: border-box;
    padding-top: var(--nav-height, 64px);
  }

  .how-header {
    flex-shrink: 0;
    padding: var(--space-lg) var(--space-lg) 0;
  }

  /* ─── Cards area ── */
  .how-cards-area {
    flex: 1;
    min-height: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Cards viewport */
  .how-cards-viewport {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .how-cards-track {
    display: flex;
    width: 300%;
    will-change: transform;
  }

  .how-card {
    width: calc(100% / 3);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    flex-shrink: 0;
  }

  .how-card-inner {
    max-width: 700px;
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--bg-border);
    border-radius: 20px;
    padding: 3rem;
    position: relative;
  }

  .how-card-1 .how-card-inner { border-color: rgba(0,240,255,0.3); box-shadow: 0 0 60px rgba(0,240,255,0.06); }
  .how-card-2 .how-card-inner { border-color: rgba(0,255,136,0.3); box-shadow: 0 0 60px rgba(0,255,136,0.06); }
  .how-card-3 .how-card-inner { border-color: rgba(139,92,246,0.3); box-shadow: 0 0 60px rgba(139,92,246,0.06); }

  .card-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    right: 2rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    animation: pulse-hint 2s ease-in-out infinite;
  }

  @keyframes pulse-hint {
    0%, 100% { opacity: 0.4; transform: translateX(0); }
    50% { opacity: 1; transform: translateX(4px); }
  }

  .step-visual {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .step-icon {
    width: 72px;
    height: 72px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-icon-1 { background: rgba(0, 240, 255, 0.1); border: 1px solid rgba(0, 240, 255, 0.3); }
  .step-icon-2 { background: rgba(0, 255, 136, 0.1); border: 1px solid rgba(0, 255, 136, 0.3); }
  .step-icon-3 { background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.3); }

  .step-number {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .step-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .step-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .step-code { font-size: 0.75rem; }

  .step-metrics {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid var(--bg-border);
  }

  .metric-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .flywheel {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: rgba(139, 92, 246, 0.04);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 12px;
    position: relative;
    flex-wrap: wrap;
  }

  .fw-step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 120px;
  }

  .fw-step-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fw-step-icon--fees {
    background: rgba(0, 240, 255, 0.1);
    border: 1px solid rgba(0, 240, 255, 0.25);
    color: var(--cyan);
  }

  .fw-step-icon--buyback {
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.25);
    color: var(--purple);
  }

  .fw-step-icon--value {
    background: rgba(0, 255, 136, 0.1);
    border: 1px solid rgba(0, 255, 136, 0.25);
    color: var(--green);
  }

  .fw-step-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .fw-step-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
  }

  .fw-step-sub {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.35);
  }

  .fw-connector {
    color: rgba(139, 92, 246, 0.4);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .fw-loop {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .fw-loop svg {
    flex: 1;
  }

  .fw-loop-label {
    font-size: 0.65rem;
    color: rgba(139, 92, 246, 0.5);
    white-space: nowrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Dots */
  .how-dots {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 10;
  }

  .how-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bg-border);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .how-dot.active {
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
    width: 24px;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .how-card-inner { padding: 2rem; }
    .step-title { font-size: 1.4rem; }
    .how-card { padding: 1rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─── Header reveals ───────────────────────────────────
  gsap.set(['#how-label', '#how-title'], { y: 60, opacity: 0 });

  ScrollTrigger.create({
    trigger: '.how-header',
    start: 'top 80%',
    onEnter: () => {
      gsap.to('#how-label', { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' });
      gsap.to('#how-title', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.1 });
    }
  });

  // ─── Horizontal scroll pinned to section ────────────────
  const section = document.querySelector('.how-section') as HTMLElement;
  const track = document.getElementById('how-cards-track');
  const dots = document.querySelectorAll('.how-dot');

  function updateDots(idx: number) {
    dots.forEach((d, i) => d.classList.toggle('active', i === idx));
  }

  if (section && track) {
    // Build a tween that slides the track from card 1 to card 3
    const scrollTween = gsap.to(track, {
      xPercent: -66.666,
      ease: 'none',
    });

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${window.innerWidth * 2}`,
      pin: true,
      pinSpacing: true,
      scrub: 1,
      animation: scrollTween,
      onUpdate: (self) => {
        const stepIdx = Math.min(2, Math.floor(self.progress * 3));
        updateDots(stepIdx);
      }
    });
  }

  // Dot click navigation
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      if (!section) return;
      const st = ScrollTrigger.getAll().find(t => t.trigger === section);
      if (st) {
        const targetProgress = i / 2.5;
        const targetScroll = st.start + (st.end - st.start) * targetProgress;
        window.scrollTo({ top: targetScroll, behavior: 'smooth' });
      }
    });
  });
</script>
