---
---
<section class="how-section" id="how-it-works">
  <!-- Section header — slides up on scroll -->
  <div class="how-header container">
    <div class="reveal-mask">
      <div class="section-label reveal-text" id="how-label">Process</div>
    </div>
    <div class="reveal-mask">
      <h2 class="section-title reveal-text" id="how-title">How OpenTrade Works</h2>
    </div>
    <div class="reveal-mask">
      <p class="how-subtitle reveal-text" id="how-subtitle">Three steps from deploy to earning. No trading knowledge required.</p>
    </div>
  </div>

  <!-- Sticky scroll container -->
  <div class="how-sticky-outer" id="how-sticky-outer">
    <div class="how-sticky-inner" id="how-sticky-inner">
      <!-- Progress indicator -->
      <div class="how-progress-bar" id="how-progress-bar">
        <div class="how-progress-fill" id="how-progress-fill"></div>
      </div>

      <!-- Step counter -->
      <div class="how-step-counter" id="how-step-counter">
        <span class="step-current mono" id="how-current-step">01</span>
        <span class="step-sep mono">/</span>
        <span class="step-total mono">03</span>
      </div>

      <!-- Horizontal cards track -->
      <div class="how-cards-viewport">
        <div class="how-cards-track" id="how-cards-track">

          <!-- Step 1 -->
          <div class="how-card how-card-1">
            <div class="how-card-inner">
              <div class="step-visual">
                <div class="step-icon step-icon-1">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="20" stroke="#00F0FF" stroke-width="1.5" opacity="0.3"/>
                    <circle cx="24" cy="24" r="12" stroke="#00F0FF" stroke-width="1.5"/>
                    <path d="M24 16v8l5 5" stroke="#00F0FF" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="24" cy="24" r="2" fill="#00F0FF"/>
                  </svg>
                </div>
              </div>
              <div class="step-content">
                <div class="step-number mono" style="color:var(--cyan)">01</div>
                <h3 class="step-title">Configure Your Agent</h3>
                <p class="step-desc">
                  Define your trading strategy — momentum, mean reversion, sentiment, or arbitrage.
                  Set risk parameters, capital allocation, and pair preferences.
                  Your agent learns and adapts autonomously.
                </p>
                <div class="step-code terminal">
                  <div class="terminal-header" style="padding:0.35rem 0.75rem">
                    <div class="terminal-dot" style="background:#FF5F56"></div>
                    <div class="terminal-dot" style="background:#FFBD2E"></div>
                    <div class="terminal-dot" style="background:#27C93F"></div>
                  </div>
                  <div class="terminal-body" style="padding:0.75rem 1rem;font-size:0.75rem">
                    <div class="terminal-prompt" style="color:#e0e8ff">agent create \</div>
                    <div style="color:#8090b0;margin-left:1rem">--strategy momentum \</div>
                    <div style="color:#8090b0;margin-left:1rem">--pairs ETH,SOL,BASE \</div>
                    <div style="color:#8090b0;margin-left:1rem">--max-risk 0.02</div>
                  </div>
                </div>
              </div>
              <div class="card-scroll-hint">Scroll to continue →</div>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="how-card how-card-2">
            <div class="how-card-inner">
              <div class="step-visual">
                <div class="step-icon step-icon-2">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                    <rect x="8" y="28" width="6" height="14" rx="1" fill="#00FF88" opacity="0.8"/>
                    <rect x="18" y="18" width="6" height="24" rx="1" fill="#00FF88"/>
                    <rect x="28" y="12" width="6" height="30" rx="1" fill="#00FF88" opacity="0.9"/>
                    <rect x="38" y="22" width="6" height="20" rx="1" fill="#00FF88" opacity="0.6"/>
                    <path d="M8 32L18 22L28 16L38 26" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="8" cy="32" r="2" fill="#00F0FF"/>
                    <circle cx="18" cy="22" r="2" fill="#00F0FF"/>
                    <circle cx="28" cy="16" r="2" fill="#00F0FF"/>
                    <circle cx="38" cy="26" r="2" fill="#00F0FF"/>
                  </svg>
                </div>
              </div>
              <div class="step-content">
                <div class="step-number mono" style="color:var(--green)">02</div>
                <h3 class="step-title">Agent Trades 24/7</h3>
                <p class="step-desc">
                  Once deployed, your agent executes trades autonomously — analyzing on-chain data,
                  news sentiment, and price action. No emotions, no fatigue.
                  Pure algorithmic precision around the clock.
                </p>
                <div class="step-metrics">
                  <div class="metric-row">
                    <span class="metric-label">Execution Speed</span>
                    <span class="metric-value glow-green">&lt;50ms</span>
                  </div>
                  <div class="metric-row">
                    <span class="metric-label">Uptime</span>
                    <span class="metric-value glow-cyan">99.97%</span>
                  </div>
                  <div class="metric-row">
                    <span class="metric-label">Avg Win Rate</span>
                    <span class="metric-value" style="color:var(--cyan)">67.8%</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="how-card how-card-3">
            <div class="how-card-inner">
              <div class="step-visual">
                <div class="step-icon step-icon-3">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                    <path d="M24 8C15.2 8 8 15.2 8 24C8 32.8 15.2 40 24 40C32.8 40 40 32.8 40 24C40 15.2 32.8 8 24 8Z" stroke="#8B5CF6" stroke-width="1.5"/>
                    <path d="M24 14v6M24 28v6M14 24h6M28 24h6" stroke="#8B5CF6" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="24" cy="24" r="4" fill="#8B5CF6" opacity="0.6"/>
                    <path d="M18 18l-3-3M30 18l3-3M30 30l3 3M18 30l-3 3" stroke="#8B5CF6" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
                  </svg>
                </div>
              </div>
              <div class="step-content">
                <div class="step-number mono" style="color:var(--purple)">03</div>
                <h3 class="step-title">Buyback Flywheel</h3>
                <p class="step-desc">
                  Your agent's token benefits from automatic buybacks — trading fees trigger
                  fee buybacks, profits trigger profit buybacks. A self-sustaining value loop
                  that compounds as your agent performs.
                </p>
                <div class="flywheel-mini">
                  <div class="fw-item">
                    <span class="fw-icon">
                      <!-- DollarSign -->
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </span>
                    <span>Fees</span>
                  </div>
                  <div class="fw-arrow">→</div>
                  <div class="fw-item">
                    <span class="fw-icon">
                      <!-- RefreshCw -->
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                    </span>
                    <span>Buyback</span>
                  </div>
                  <div class="fw-arrow">→</div>
                  <div class="fw-item">
                    <span class="fw-icon">
                      <!-- TrendingUp -->
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </span>
                    <span>Token ↑</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Step dots navigation -->
      <div class="how-dots" id="how-dots">
        <button class="how-dot active" data-step="0"></button>
        <button class="how-dot" data-step="1"></button>
        <button class="how-dot" data-step="2"></button>
      </div>
    </div>
  </div>
</section>

<style>
  .how-section {
    position: relative;
    overflow: hidden;
    background: var(--bg-base);
  }

  .how-header {
    padding: var(--space-3xl) 0 var(--space-xl);
  }

  .how-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-top: 0.75rem;
    max-width: 500px;
  }

  /* ─── Sticky section ── */
  .how-sticky-outer {
    /* Height = viewport * number of cards (scroll distance) */
    height: 300vh;
    position: relative;
  }

  .how-sticky-inner {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Progress bar at top */
  .how-progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(0, 240, 255, 0.1);
    z-index: 10;
  }

  .how-progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--cyan), var(--green));
    box-shadow: 0 0 10px var(--cyan);
    transition: width 0.1s linear;
  }

  /* Step counter */
  .how-step-counter {
    position: absolute;
    top: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    z-index: 10;
  }

  .step-current {
    color: var(--cyan);
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* Cards viewport */
  .how-cards-viewport {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .how-cards-track {
    display: flex;
    width: 300%; /* 3 cards */
    will-change: transform;
  }

  .how-card {
    width: calc(100% / 3); /* Each card = 1 viewport width */
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    flex-shrink: 0;
  }

  .how-card-inner {
    max-width: 700px;
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--bg-border);
    border-radius: 20px;
    padding: 3rem;
    position: relative;
  }

  .how-card-1 .how-card-inner { border-color: rgba(0,240,255,0.3); box-shadow: 0 0 60px rgba(0,240,255,0.06); }
  .how-card-2 .how-card-inner { border-color: rgba(0,255,136,0.3); box-shadow: 0 0 60px rgba(0,255,136,0.06); }
  .how-card-3 .how-card-inner { border-color: rgba(139,92,246,0.3); box-shadow: 0 0 60px rgba(139,92,246,0.06); }

  .card-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    right: 2rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    animation: pulse-hint 2s ease-in-out infinite;
  }

  @keyframes pulse-hint {
    0%, 100% { opacity: 0.4; transform: translateX(0); }
    50% { opacity: 1; transform: translateX(4px); }
  }

  .step-visual {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .step-icon {
    width: 72px;
    height: 72px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-icon-1 { background: rgba(0, 240, 255, 0.1); border: 1px solid rgba(0, 240, 255, 0.3); }
  .step-icon-2 { background: rgba(0, 255, 136, 0.1); border: 1px solid rgba(0, 255, 136, 0.3); }
  .step-icon-3 { background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.3); }

  .step-number {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .step-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .step-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .step-code { font-size: 0.75rem; }

  .step-metrics {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid var(--bg-border);
  }

  .metric-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .flywheel-mini {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 8px;
  }

  .fw-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--purple);
    font-weight: 600;
  }

  .fw-icon { display: flex; align-items: center; }
  .fw-arrow { color: var(--text-muted); font-size: 1rem; }

  /* Dots */
  .how-dots {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 10;
  }

  .how-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bg-border);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .how-dot.active {
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
    width: 24px;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .how-sticky-outer { height: 400vh; }
    .how-card-inner { padding: 2rem; }
    .step-title { font-size: 1.4rem; }
    .how-card { padding: 1rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─── Header reveals ───────────────────────────────────
  gsap.set(['#how-label', '#how-title', '#how-subtitle'], { y: 60, opacity: 0 });

  ScrollTrigger.create({
    trigger: '.how-header',
    start: 'top 80%',
    onEnter: () => {
      gsap.to('#how-label', { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' });
      gsap.to('#how-title', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.1 });
      gsap.to('#how-subtitle', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.2 });
    }
  });

  // ─── Sticky horizontal scroll ────────────────────────
  const track = document.getElementById('how-cards-track');
  const progressFill = document.getElementById('how-progress-fill');
  const currentStepEl = document.getElementById('how-current-step');
  const dots = document.querySelectorAll('.how-dot');

  function updateDots(idx: number) {
    dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    if (currentStepEl) {
      currentStepEl.textContent = String(idx + 1).padStart(2, '0');
    }
  }

  ScrollTrigger.create({
    trigger: '#how-sticky-outer',
    pin: '#how-sticky-inner',
    start: 'top top',
    end: 'bottom bottom',
    scrub: 1,
    onUpdate: (self) => {
      const progress = self.progress;
      // Track is 300% wide (3 cards × 100vw each).
      // To show card 1: xPercent = 0
      // To show card 2: xPercent = -33.333 (of 300% = -100vw)
      // To show card 3: xPercent = -66.666 (of 300% = -200vw)
      // So total xPercent range: 0 → -66.666
      if (track) {
        gsap.set(track, { xPercent: -(progress * 66.666) });
      }
      // Progress bar
      if (progressFill) progressFill.style.width = `${progress * 100}%`;

      // Update dots and counter
      const stepIdx = Math.min(2, Math.floor(progress * 3));
      updateDots(stepIdx);
    }
  });

  // Dot click navigation (scroll to section position)
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      const outer = document.getElementById('how-sticky-outer');
      if (!outer) return;
      const rect = outer.getBoundingClientRect();
      const sectionTop = window.scrollY + rect.top;
      const sectionHeight = outer.offsetHeight;
      const progress = i / 3;
      const targetY = sectionTop + sectionHeight * progress;
      window.scrollTo({ top: targetY, behavior: 'smooth' });
    });
  });
</script>
