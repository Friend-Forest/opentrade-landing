---
---
<section class="how-section" id="how-it-works">
  <div class="how-header">
    <div class="reveal-mask">
      <div class="section-label reveal-text" id="how-label">Process</div>
    </div>
    <div class="reveal-mask">
      <h2 class="section-title reveal-text" id="how-title">How OpenTrade Works</h2>
    </div>
  </div>

  <div class="how-cards-area">
    <!-- Horizontal cards track -->
    <div class="how-cards-viewport">
      <div class="how-cards-track" id="how-cards-track">

        <!-- Step 1 -->
        <div class="how-card how-card-1">
          <div class="how-card-inner">
            <div class="step-visual">
              <div class="step-icon step-icon-1">
                <svg width="20" height="20" viewBox="0 0 82.5 82.5" fill="none"><circle cx="35.8" cy="2.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="8.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="8.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="8.2" r="2.3" fill="currentColor"/><circle cx="24.8" cy="13.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="13.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="13.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="13.8" r="2.3" fill="currentColor"/><circle cx="46.8" cy="13.8" r="2.3" fill="currentColor"/><circle cx="19.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="24.8" cy="19.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="19.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="46.8" cy="19.2" r="2.3" fill="currentColor"/><circle cx="52.2" cy="19.2" r="2.3" fill="currentColor"/><circle cx="13.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="19.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="24.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="46.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="52.2" cy="24.8" r="2.3" fill="currentColor"/><circle cx="57.8" cy="24.8" r="2.3" fill="currentColor"/><circle cx="8.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="13.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="19.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="24.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="46.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="52.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="57.8" cy="30.2" r="2.3" fill="currentColor"/><circle cx="63.2" cy="30.2" r="2.3" fill="currentColor"/><circle cx="2.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="8.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="13.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="19.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="24.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="46.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="52.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="57.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="63.2" cy="35.8" r="2.3" fill="currentColor"/><circle cx="68.8" cy="35.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="41.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="41.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="41.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="46.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="46.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="46.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="52.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="52.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="52.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="57.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="57.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="57.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="63.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="63.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="63.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="68.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="68.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="68.8" r="2.3" fill="currentColor"/><circle cx="30.2" cy="74.2" r="2.3" fill="currentColor"/><circle cx="35.8" cy="74.2" r="2.3" fill="currentColor"/><circle cx="41.2" cy="74.2" r="2.3" fill="currentColor"/><circle cx="30.2" cy="79.8" r="2.3" fill="currentColor"/><circle cx="35.8" cy="79.8" r="2.3" fill="currentColor"/><circle cx="41.2" cy="79.8" r="2.3" fill="currentColor"/></svg>
              </div>
            </div>
            <div class="step-content">
              <div class="step-number mono" style="color:#888888">01</div>
              <h3 class="step-title">Create Your Agent</h3>
              <p class="step-desc">
                Pick a strategy. Set risk limits. Choose your markets. crypto, stocks, prediction markets, anything.
                Your AI agent discovers available plugins automatically and adapts to whatever tools are available.
                No code required.
              </p>
              <div class="step-code terminal">
                <div class="terminal-header" style="padding:0.35rem 0.75rem">
                  <div class="terminal-dot" style="background:#FF5F56"></div>
                  <div class="terminal-dot" style="background:#FFBD2E"></div>
                  <div class="terminal-dot" style="background:#27C93F"></div>
                </div>
                <div class="terminal-body" style="padding:0.75rem 1rem;font-size:0.75rem">
                  <div class="terminal-prompt" style="color:var(--text-primary)">agent create \</div>
                  <div style="color:var(--text-secondary);margin-left:1rem">--strategy momentum \</div>
                  <div style="color:var(--text-secondary);margin-left:1rem">--pairs ETH,SOL,BASE \</div>
                  <div style="color:var(--text-secondary);margin-left:1rem">--max-risk 0.02</div>
                </div>
              </div>
            </div>
            <div class="card-scroll-hint">Scroll to continue →</div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="how-card how-card-2">
          <div class="how-card-inner">
            <div class="step-visual">
              <div class="step-icon step-icon-2">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              </div>
            </div>
            <div class="step-content">
              <div class="step-number mono" style="color:#888888">02</div>
              <h3 class="step-title">Agent Executes Autonomously</h3>
              <p class="step-desc">
                Your agent pulls real-time data, reasons about market conditions, and executes trades. across any market.
                0.5% fee on every trade. 80% buys back $OT. The more agents trade, the more buy pressure.
                Zero emotions. Zero downtime.
              </p>
              <div class="step-metrics">
                <div class="metric-row">
                  <span class="metric-label">Execution Speed</span>
                  <span class="metric-value glow-green">&lt;50ms</span>
                </div>
                <div class="metric-row">
                  <span class="metric-label">Uptime</span>
                  <span class="metric-value glow-cyan">99.97%</span>
                </div>
                <div class="metric-row">
                  <span class="metric-label">Avg Win Rate</span>
                  <span class="metric-value" style="color:var(--cyan)">67.8%</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="how-card how-card-3">
          <div class="how-card-inner">
            <div class="step-visual">
              <div class="step-icon step-icon-3">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              </div>
            </div>
            <div class="step-content">
              <div class="step-number mono" style="color:#888888">03</div>
              <h3 class="step-title">Launch Your Token</h3>
              <p class="step-desc">
                Launch an agent token. 80% of fees compound the agent's wallet, 20% buys back $OT.
                5–25% of profits trigger agent token buybacks.
              </p>
              <div class="flywheel">
                <div class="fw-step">
                  <div class="fw-step-icon fw-step-icon--fees">
                    <span class="pixel-icon" style="font-size:1.5rem">$</span>
                  </div>
                  <div class="fw-step-text">
                    <span class="fw-step-label">Agent Fees</span>
                    <span class="fw-step-sub">0.5% on every trade → 80% to $OT buyback</span>
                  </div>
                </div>
                <div class="fw-connector">
                  <span class="pixel-icon" style="font-size:1.2rem">→</span>
                </div>
                <div class="fw-step">
                  <div class="fw-step-icon fw-step-icon--buyback">
                    <span class="pixel-icon" style="font-size:1.5rem">↻</span>
                  </div>
                  <div class="fw-step-text">
                    <span class="fw-step-label">Token Launch</span>
                    <span class="fw-step-sub">80% compounds, 20% → $OT buyback</span>
                  </div>
                </div>
                <div class="fw-connector">
                  <span class="pixel-icon" style="font-size:1.2rem">→</span>
                </div>
                <div class="fw-step">
                  <div class="fw-step-icon fw-step-icon--value">
                    <span class="pixel-icon" style="font-size:1.5rem">↑</span>
                  </div>
                  <div class="fw-step-text">
                    <span class="fw-step-label">Profit Buyback</span>
                    <span class="fw-step-sub">5–25% of profits → agent token buyback</span>
                  </div>
                </div>
                <div class="fw-loop">
                  <svg width="100%" height="24" viewBox="0 0 400 24" preserveAspectRatio="none" fill="none">
                    <path d="M400 4C300 4 300 20 200 20S100 4 0 4" stroke="rgba(139,92,246,0.3)" stroke-width="1.5" stroke-dasharray="4 4"/>
                  </svg>
                  <span class="fw-loop-label mono">Cycle repeats</span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .how-section {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-base);
    overflow: hidden;
    box-sizing: border-box;
    padding-top: var(--nav-height, 80px);
  }

  .how-header {
    flex-shrink: 0;
    padding: var(--space-lg) var(--space-lg) 0;
  }

  /* ─── Cards area ── */
  .how-cards-area {
    flex: 1;
    min-height: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Cards viewport */
  .how-cards-viewport {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .how-cards-track {
    display: flex;
    width: 300%;
    will-change: transform;
  }

  .how-card {
    width: calc(100% / 3);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    flex-shrink: 0;
  }

  .how-card-inner {
    max-width: 700px;
    width: 100%;
    background: var(--bg-card);
    border: 2px solid var(--bg-border);
    border-radius: 0;
    padding: 3rem;
    position: relative;
  }

  .how-card-1 .how-card-inner { border-color: #333333; }
  .how-card-2 .how-card-inner { border-color: #333333; }
  .how-card-3 .how-card-inner { border-color: #333333; }

  .card-scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    right: 2rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    animation: pulse-hint 2s ease-in-out infinite;
  }

  @keyframes pulse-hint {
    0%, 100% { opacity: 0.4; transform: translateX(0); }
    50% { opacity: 1; transform: translateX(4px); }
  }

  .step-visual {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .step-icon {
    width: 72px;
    height: 72px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-icon-1 { background: rgba(255, 255, 255, 0.05); border: 1px solid #333333; }
  .step-icon-2 { background: rgba(255, 255, 255, 0.05); border: 1px solid #333333; }
  .step-icon-3 { background: rgba(255, 255, 255, 0.05); border: 1px solid #333333; }

  .step-number {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .step-title {
    font-family: var(--font-pixel);
    font-size: 1.75rem;
    font-weight: 300;
    margin-bottom: 1rem;
    letter-spacing: 0;
    color: #ffffff;
  }

  .step-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .step-code { font-size: 0.75rem; }

  .step-metrics {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid var(--bg-border);
  }

  .metric-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .flywheel {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid #333333;
    border-radius: 0;
    position: relative;
    flex-wrap: wrap;
  }

  .fw-step {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 120px;
  }

  .fw-step-icon {
    width: 44px;
    height: 44px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fw-step-icon--fees {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid #333333;
    color: #ffffff;
  }

  .fw-step-icon--buyback {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid #333333;
    color: #ffffff;
  }

  .fw-step-icon--value {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: var(--green);
  }

  .fw-step-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .fw-step-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
  }

  .fw-step-sub {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.35);
  }

  .fw-connector {
    color: rgba(139, 92, 246, 0.4);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .fw-loop {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .fw-loop svg {
    flex: 1;
  }

  .fw-loop-label {
    font-size: 0.65rem;
    color: rgba(139, 92, 246, 0.5);
    white-space: nowrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .how-card-inner { padding: 2rem; }
    .step-title { font-size: 1.4rem; }
    .how-card { padding: 1rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─── Header reveals ───────────────────────────────────
  gsap.set(['#how-label', '#how-title'], { y: 60, opacity: 0 });

  ScrollTrigger.create({
    trigger: '.how-header',
    start: 'top 80%',
    onEnter: () => {
      gsap.to('#how-label', { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' });
      gsap.to('#how-title', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: 0.1 });
    }
  });

  // ─── Horizontal scroll pinned to section ────────────────
  const section = document.querySelector('.how-section') as HTMLElement;
  const track = document.getElementById('how-cards-track');

  if (section && track) {
    // Build a tween that slides the track from card 1 to card 3
    const scrollTween = gsap.to(track, {
      xPercent: -66.666,
      ease: 'none',
    });

    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: () => `+=${window.innerWidth * 2}`,
      pin: true,
      pinSpacing: true,
      scrub: 1,
      animation: scrollTween,
      onUpdate: (self) => {
        // Dots removed
      }
    });
  }

</script>
