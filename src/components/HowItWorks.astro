---
---
<section class="how-section" id="how-it-works">
  <div class="container">
    <div class="section-label">Process</div>
    <h2 class="section-title">How OpenTrade Works</h2>
    <p class="how-subtitle">Three steps from deploy to earning. No trading knowledge required.</p>
  </div>

  <div class="how-steps-wrapper">
    <div class="how-steps container">
      <!-- Step 1 -->
      <div class="how-step" data-step="01">
        <div class="step-visual">
          <div class="step-icon step-icon-1">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="24" r="20" stroke="#00F0FF" stroke-width="1.5" opacity="0.3"/>
              <circle cx="24" cy="24" r="12" stroke="#00F0FF" stroke-width="1.5"/>
              <path d="M24 16v8l5 5" stroke="#00F0FF" stroke-width="2" stroke-linecap="round"/>
              <circle cx="24" cy="24" r="2" fill="#00F0FF"/>
            </svg>
          </div>
          <div class="step-connector"></div>
        </div>
        <div class="step-content">
          <div class="step-number mono" style="color:var(--cyan)">01</div>
          <h3 class="step-title">Configure Your Agent</h3>
          <p class="step-desc">
            Define your trading strategy — momentum, mean reversion, sentiment, or arbitrage.
            Set risk parameters, capital allocation, and pair preferences.
            Your agent learns and adapts autonomously.
          </p>
          <div class="step-code terminal">
            <div class="terminal-header" style="padding:0.35rem 0.75rem">
              <div class="terminal-dot" style="background:#FF5F56"></div>
              <div class="terminal-dot" style="background:#FFBD2E"></div>
              <div class="terminal-dot" style="background:#27C93F"></div>
            </div>
            <div class="terminal-body" style="padding:0.75rem 1rem;font-size:0.75rem">
              <div class="terminal-prompt" style="color:#e0e8ff">agent create \</div>
              <div style="color:#8090b0;margin-left:1rem">--strategy momentum \</div>
              <div style="color:#8090b0;margin-left:1rem">--pairs ETH,SOL,BASE \</div>
              <div style="color:#8090b0;margin-left:1rem">--max-risk 0.02</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="how-step" data-step="02">
        <div class="step-visual">
          <div class="step-icon step-icon-2">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <rect x="8" y="28" width="6" height="14" rx="1" fill="#00FF88" opacity="0.8"/>
              <rect x="18" y="18" width="6" height="24" rx="1" fill="#00FF88"/>
              <rect x="28" y="12" width="6" height="30" rx="1" fill="#00FF88" opacity="0.9"/>
              <rect x="38" y="22" width="6" height="20" rx="1" fill="#00FF88" opacity="0.6"/>
              <path d="M8 32L18 22L28 16L38 26" stroke="#00F0FF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="8" cy="32" r="2" fill="#00F0FF"/>
              <circle cx="18" cy="22" r="2" fill="#00F0FF"/>
              <circle cx="28" cy="16" r="2" fill="#00F0FF"/>
              <circle cx="38" cy="26" r="2" fill="#00F0FF"/>
            </svg>
          </div>
          <div class="step-connector"></div>
        </div>
        <div class="step-content">
          <div class="step-number mono" style="color:var(--green)">02</div>
          <h3 class="step-title">Agent Trades 24/7</h3>
          <p class="step-desc">
            Once deployed, your agent executes trades autonomously — analyzing on-chain data,
            news sentiment, and price action. No emotions, no fatigue.
            Pure algorithmic precision around the clock.
          </p>
          <div class="step-metrics">
            <div class="metric-row">
              <span class="metric-label">Execution Speed</span>
              <span class="metric-value glow-green">&lt;50ms</span>
            </div>
            <div class="metric-row">
              <span class="metric-label">Uptime</span>
              <span class="metric-value glow-cyan">99.97%</span>
            </div>
            <div class="metric-row">
              <span class="metric-label">Avg Win Rate</span>
              <span class="metric-value" style="color:var(--cyan)">67.8%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="how-step" data-step="03">
        <div class="step-visual">
          <div class="step-icon step-icon-3">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <path d="M24 8C15.2 8 8 15.2 8 24C8 32.8 15.2 40 24 40C32.8 40 40 32.8 40 24C40 15.2 32.8 8 24 8Z" stroke="#8B5CF6" stroke-width="1.5"/>
              <path d="M24 14v6M24 28v6M14 24h6M28 24h6" stroke="#8B5CF6" stroke-width="2" stroke-linecap="round"/>
              <circle cx="24" cy="24" r="4" fill="#8B5CF6" opacity="0.6"/>
              <path d="M18 18l-3-3M30 18l3-3M30 30l3 3M18 30l-3 3" stroke="#8B5CF6" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
            </svg>
          </div>
        </div>
        <div class="step-content">
          <div class="step-number mono" style="color:var(--purple)">03</div>
          <h3 class="step-title">Buyback Flywheel</h3>
          <p class="step-desc">
            Your agent's token benefits from automatic buybacks — trading fees trigger
            fee buybacks, profits trigger profit buybacks. A self-sustaining value loop
            that compounds as your agent performs.
          </p>
          <div class="flywheel-mini">
            <div class="fw-item">
              <span class="fw-icon">💰</span>
              <span>Fees</span>
            </div>
            <div class="fw-arrow">→</div>
            <div class="fw-item">
              <span class="fw-icon">🔄</span>
              <span>Buyback</span>
            </div>
            <div class="fw-arrow">→</div>
            <div class="fw-item">
              <span class="fw-icon">📈</span>
              <span>Token ↑</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .how-section {
    padding: var(--space-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  .how-section .container {
    margin-bottom: 3rem;
  }

  .how-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-top: 0.75rem;
    max-width: 500px;
  }

  .how-steps-wrapper {
    position: relative;
  }

  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    position: relative;
  }

  .how-step {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--bg-border);
    border-right: none;
    background: var(--bg-card);
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s ease;
    position: relative;
  }

  .how-step:first-child { border-radius: 12px 0 0 12px; }
  .how-step:last-child { border-right: 1px solid var(--bg-border); border-radius: 0 12px 12px 0; }

  .how-step.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .how-step:hover {
    background: var(--bg-hover);
  }

  .step-visual {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .step-icon {
    width: 72px;
    height: 72px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-icon-1 { background: rgba(0, 240, 255, 0.1); border: 1px solid rgba(0, 240, 255, 0.3); }
  .step-icon-2 { background: rgba(0, 255, 136, 0.1); border: 1px solid rgba(0, 255, 136, 0.3); }
  .step-icon-3 { background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.3); }

  .step-connector {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--bg-border), transparent);
  }

  .step-number {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    font-weight: 700;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .step-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .step-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  /* Code block */
  .step-code { font-size: 0.75rem; }

  /* Metrics */
  .step-metrics {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: rgba(0,0,0,0.3);
    border-radius: 6px;
    border: 1px solid var(--bg-border);
  }

  .metric-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }

  /* Flywheel mini */
  .flywheel-mini {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(139, 92, 246, 0.08);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 8px;
  }

  .fw-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--purple);
    font-weight: 600;
  }

  .fw-icon { font-size: 1.2rem; }
  .fw-arrow { color: var(--text-muted); font-size: 1rem; }

  @media (max-width: 900px) {
    .how-steps {
      grid-template-columns: 1fr;
    }

    .how-step {
      border-right: 1px solid var(--bg-border);
      border-bottom: none;
    }

    .how-step:first-child { border-radius: 12px 12px 0 0; }
    .how-step:last-child { border-radius: 0 0 12px 12px; border-bottom: 1px solid var(--bg-border); }

    .step-connector { display: none; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const steps = document.querySelectorAll('.how-step');
        steps.forEach((step, i) => {
          setTimeout(() => step.classList.add('visible'), i * 200);
        });
        observer.disconnect();
      }
    });
  }, { threshold: 0.2 });

  const section = document.querySelector('.how-steps');
  if (section) observer.observe(section);
</script>
