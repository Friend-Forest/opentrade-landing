---
---
<section class="marketplace-section" id="marketplace">
  <div class="container">
    <div class="marketplace-header">
      <div class="section-label">Ecosystem</div>
      <h2 class="section-title">Plugin Marketplace</h2>
      <p class="marketplace-desc">
        Every component of OpenTrade is a swappable plugin. Data sources, trade execution, storage, even the AI brain.
        Build plugins, publish them, and earn revenue. 20% of all marketplace sales buy back $OT.
      </p>
    </div>

    <div class="plugin-grid">
      <!-- Oracle Plugins -->
      <div class="plugin-card">
        <div class="plugin-header">
          <div class="plugin-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 class="plugin-title">Oracle Plugins</h3>
        </div>
        <p class="plugin-desc">Bring in external data. Prices, sentiment, on-chain signals, news feeds. The AI agent picks which oracles to use based on the situation.</p>
        <div class="plugin-examples">
          <span class="plugin-tag">CoinGecko</span>
          <span class="plugin-tag">X / Twitter</span>
          <span class="plugin-tag">Chainlink</span>
          <span class="plugin-tag">Bloomberg</span>
          <span class="plugin-tag">Custom APIs</span>
        </div>
      </div>

      <!-- Trade Plugins -->
      <div class="plugin-card">
        <div class="plugin-header">
          <div class="plugin-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </div>
          <h3 class="plugin-title">Trade Plugins</h3>
        </div>
        <p class="plugin-desc">Execute trades on any venue. DEXs, CEXs, prediction markets, brokerages. One agent, every market. Just swap the plugin.</p>
        <div class="plugin-examples">
          <span class="plugin-tag">Uniswap</span>
          <span class="plugin-tag">Polymarket</span>
          <span class="plugin-tag">Jupiter</span>
          <span class="plugin-tag">Coinbase</span>
          <span class="plugin-tag">Paper Trading</span>
        </div>
      </div>

      <!-- Agent Plugins -->
      <div class="plugin-card">
        <div class="plugin-header">
          <div class="plugin-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/><circle cx="12" cy="15" r="2"/></svg>
          </div>
          <h3 class="plugin-title">Agent Plugins</h3>
        </div>
        <p class="plugin-desc">The AI brain. Swap between Claude, GPT, custom strategy bots, or rule-based engines. The agent discovers tools at runtime, no reconfiguration needed.</p>
        <div class="plugin-examples">
          <span class="plugin-tag">Claude</span>
          <span class="plugin-tag">GPT-4</span>
          <span class="plugin-tag">Custom Bots</span>
          <span class="plugin-tag">Rule Engines</span>
        </div>
      </div>

      <!-- State Plugins -->
      <div class="plugin-card">
        <div class="plugin-header">
          <div class="plugin-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <h3 class="plugin-title">State Plugins</h3>
        </div>
        <p class="plugin-desc">Store and recall information. In-memory for speed, SQLite for persistence, Redis for scale. Full audit trail on every decision.</p>
        <div class="plugin-examples">
          <span class="plugin-tag">SQLite</span>
          <span class="plugin-tag">Redis</span>
          <span class="plugin-tag">In-Memory</span>
          <span class="plugin-tag">Cloud DB</span>
        </div>
      </div>
    </div>

    <!-- Bottom row: Analytics + Hosted -->
    <div class="features-row">
      <div class="feature-block">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </div>
        <h3 class="feature-title">Plugin Analytics</h3>
        <p class="feature-desc">
          Track plugin usage, response times, error rates, and performance.
          Developers get dashboards to understand adoption.
          The marketplace ranks plugins by real performance data, not just downloads.
        </p>
        <div class="feature-stats">
          <div class="feature-stat">
            <span class="feature-stat-value">API calls</span>
            <span class="feature-stat-label">Tracked per plugin</span>
          </div>
          <div class="feature-stat">
            <span class="feature-stat-value">Win rate</span>
            <span class="feature-stat-label">Agent performance</span>
          </div>
          <div class="feature-stat">
            <span class="feature-stat-value">Latency</span>
            <span class="feature-stat-label">Oracle reliability</span>
          </div>
        </div>
      </div>

      <div class="feature-block">
        <div class="feature-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        </div>
        <h3 class="feature-title">Hosted Service</h3>
        <p class="feature-desc">
          Run OpenTrade locally or let us handle it.
          Hosted agents run 24/7 on managed infrastructure.
          Wallet generated on signup, trades executing in seconds, zero ops burden.
        </p>
        <div class="feature-stats">
          <div class="feature-stat">
            <span class="feature-stat-value">99.9%</span>
            <span class="feature-stat-label">Uptime SLA</span>
          </div>
          <div class="feature-stat">
            <span class="feature-stat-value">24/7</span>
            <span class="feature-stat-label">Always running</span>
          </div>
          <div class="feature-stat">
            <span class="feature-stat-value">0 ops</span>
            <span class="feature-stat-label">We manage infra</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .marketplace-section {
    padding: var(--space-3xl) 0;
    background: var(--bg-base);
  }

  .marketplace-header {
    max-width: 640px;
    margin-bottom: var(--space-xl);
  }

  .marketplace-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    margin-top: 1rem;
  }

  /* Plugin grid */
  .plugin-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: var(--space-xl);
  }

  .plugin-card {
    background: var(--bg-card);
    border: 1px solid var(--bg-border);
    padding: 2rem;
    transition: border-color 0.3s ease;
  }

  .plugin-card:hover {
    border-color: var(--text-muted);
  }

  .plugin-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .plugin-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--bg-border);
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .plugin-title {
    font-family: var(--font-pixel);
    font-weight: 300;
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  .plugin-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .plugin-examples {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .plugin-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--bg-border);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Features row */
  .features-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .feature-block {
    background: var(--bg-card);
    border: 1px solid var(--bg-border);
    padding: 2rem;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--bg-border);
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .feature-title {
    font-family: var(--font-pixel);
    font-weight: 300;
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .feature-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .feature-stats {
    display: flex;
    gap: 1.5rem;
  }

  .feature-stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .feature-stat-value {
    font-family: var(--font-pixel);
    font-weight: 300;
    font-size: 1rem;
    color: var(--text-primary);
  }

  .feature-stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Light mode */
  :global([data-theme="light"]) .plugin-icon,
  :global([data-theme="light"]) .feature-icon {
    background: rgba(0, 0, 0, 0.03);
  }

  :global([data-theme="light"]) .plugin-tag {
    background: rgba(0, 0, 0, 0.03);
  }

  @media (max-width: 768px) {
    .plugin-grid { grid-template-columns: 1fr; }
    .features-row { grid-template-columns: 1fr; }
    .feature-stats { flex-wrap: wrap; gap: 1rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Stagger reveal cards
  const cards = document.querySelectorAll('.plugin-card, .feature-block');
  gsap.set(cards, { opacity: 0, y: 30 });

  ScrollTrigger.create({
    trigger: '.marketplace-section',
    start: 'top 75%',
    onEnter: () => {
      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.1,
        ease: 'power3.out',
      });
    },
  });
</script>
